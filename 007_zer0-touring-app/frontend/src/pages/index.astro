      <button class="btn-primary" id="btn-start">コースを探す</button>
      <div class="usage-badge" id="usage-badge" style="visibility:hidden">
        <span class="dots" id="usage-dots"></span>
        <span id="usage-text"></span>
      </div>
    </div>

    <!-- ── Loading ── -->
    <div id="screen-loading" class="screen">
      <div class="riding-scene">
        <div class="rs-sky">
          <div class="rs-star"></div>
          <div class="rs-star"></div>
          <div class="rs-star"></div>
          <div class="rs-star"></div>
          <div class="rs-star"></div>
          <div class="rs-cloud a"></div>
          <div class="rs-cloud b"></div>
        </div>
        <div class="rs-mountains"></div>
        <div class="rs-road">
          <div class="rs-dashes"></div>
        </div>
        <div class="rs-exhaust">
          <div class="rs-puff"></div>
          <div class="rs-puff"></div>
          <div class="rs-puff"></div>
        </div>
        <span class="rs-bike">🏍️</span>
      </div>
      <p class="loading-title">コースを検索中<span class="loading-dots"><span>.</span><span>.</span><span>.</span></span></p>
      <div class="steps">
        <div class="step" id="step-gps"><span class="step-icon" id="icon-gps">📍</span><span id="step-gps-text">現在地を取得中</span></div>
        <div class="step" id="step-weather"><span class="step-icon" id="icon-weather">🌤</span><span>天気を確認中</span></div>
        <div class="step" id="step-ai"><span class="step-icon" id="icon-ai">🤖</span><span>AIがコースを生成中</span></div>
      </div>
    </div>

    <!-- ── コース一覧（スワイプスライダー）── -->
    <div id="screen-results" class="screen">
      <div class="topbar">
        <div class="topbar-left">
          <span class="topbar-title">おすすめコース</span>
          <span id="weather-subtitle" class="weather-subtitle"></span>
        </div>
        <div class="topbar-btns">
          <button class="btn-outline" id="btn-retry">再検索</button>
        </div>
      </div>

      <div class="slider-outer">
        <div class="slider-dots" id="slider-dots"></div>
        <div class="card-viewport" id="card-viewport">
        </div>
