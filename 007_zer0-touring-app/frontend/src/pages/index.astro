      <div class="origin-input-wrap" id="origin-input-wrap" style="display:none">
        <input class="origin-input" id="origin-input" type="text"
               placeholder="例: 横浜、新宿、名古屋駅" enterkeyhint="search" />
      </div>

      <div class="pref-section">
        <p class="pref-label">好みのスタイル（任意・複数選択可）</p>
        <div class="pref-tags" id="pref-tags">
          <button class="pref-tag" data-tag="峠道">🏔 峠道</button>
          <button class="pref-tag" data-tag="海沿い">🌊 海沿い</button>
          <button class="pref-tag" data-tag="温泉">♨️ 温泉</button>
          <button class="pref-tag" data-tag="グルメ">🍜 グルメ</button>
          <button class="pref-tag" data-tag="絶景">🌅 絶景</button>
          <button class="pref-tag" data-tag="自然">🌳 自然</button>
          <button class="pref-tag" data-tag="歴史">🏯 歴史</button>
          <button class="pref-tag" data-tag="ガッツリ走る" data-exclusive="のんびり">🛣 ガッツリ走る</button>
          <button class="pref-tag" data-tag="のんびり" data-exclusive="ガッツリ走る">☕ のんびり</button>
        </div>
