      }
      .info-return  { background: rgba(56,189,248,.1);  color: #7dd3fc; border: 1px solid rgba(56,189,248,.3); }
      .info-caution { background: rgba(239,68,68,.1);   color: #fca5a5; border: 1px solid rgba(239,68,68,.3); }
      .info-season  { background: rgba(34,197,94,.1);   color: #86efac; border: 1px solid rgba(34,197,94,.3); }
      .btn-map {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        text-decoration: none; background: transparent;
        color: var(--accent); border: 1.5px solid var(--accent);
        border-radius: .75rem; padding: .875rem; font-size: .95rem; font-weight: 600;
        transition: background .15s;
      }
      .btn-map:hover { background: rgba(249,115,22,.1); }
      .btn-x-share {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        text-decoration: none; background: #000; color: #fff;
        border-radius: .75rem; padding: .875rem; font-size: .95rem; font-weight: 600;
        transition: opacity .15s;
      }
      .btn-x-share:hover { opacity: .85; }
      .btn-url-copy {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        width: 100%; border: none; cursor: pointer;
        background: #1a2744; color: #fff;
        border-radius: .75rem; padding: .875rem; font-size: .95rem; font-weight: 600;
        transition: opacity .15s;
      }
      .btn-url-copy:hover { opacity: .85; }

      @media (max-width: 679px) {
        .detail-content { padding: 1.25rem 1rem 2rem; gap: 1.25rem; }
        .detail-name { font-size: 1.25rem; }
      }

      /* ── 出発地トグル ── */
      .loc-toggle {
        display: flex;
        background: rgba(255,255,255,.06);
        border: 1px solid var(--border);
        border-radius: 9999px;
        padding: .22rem;
        gap: .22rem;
        width: 100%; max-width: 320px;
      }
      .loc-btn {
        flex: 1; background: transparent; border: none;
        color: var(--muted); border-radius: 9999px;
        padding: .48rem .5rem; font-size: .875rem; font-weight: 500;
        cursor: pointer; transition: background .2s, color .2s; white-space: nowrap;
      }
      .loc-btn.active { background: var(--card2); color: var(--text); }

      /* ── 出発地テキスト入力 ── */
      .origin-input-wrap { width: 100%; max-width: 320px; }
      .origin-input {
        width: 100%; background: rgba(255,255,255,.07);
        border: 1.5px solid var(--border); border-radius: .75rem;
        padding: .72rem 1rem; color: var(--text); font-size: .95rem;
        outline: none; transition: border-color .2s;
      }
      .origin-input:focus { border-color: var(--accent); }
      .origin-input::placeholder { color: var(--muted); }

      /* ── 好みタグ選択 ── */
      .pref-section {
        display: flex; flex-direction: column; gap: .6rem;
        width: 100%; max-width: 340px;
      }
      .pref-label {
        font-size: .7rem; color: var(--muted); font-weight: 600;
        letter-spacing: .04em; text-align: center; text-transform: uppercase;
      }
      .pref-tags { display: grid; grid-template-columns: repeat(3, 1fr); gap: .45rem; width: 100%; }
      .pref-tag {
        background: rgba(255,255,255,.06); border: 1.5px solid var(--border);
        color: var(--muted); border-radius: 9999px;
        padding: .35rem .5rem; font-size: .82rem; font-weight: 500;
        cursor: pointer; white-space: nowrap; text-align: center;
        transition: background .15s, border-color .15s, color .15s;
      }
      .pref-tag:hover { border-color: rgba(249,115,22,.4); color: var(--text); }
      .pref-tag.selected {
        background: rgba(249,115,22,.18); border-color: var(--accent); color: var(--accent);
      }

      /* ── Toast ── */
      #toast {
        position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%);
        background: var(--accent); color: #fff; font-size: .85rem; font-weight: 600;
        padding: .6rem 1.4rem; border-radius: 999px;
        opacity: 0; pointer-events: none; transition: opacity .3s; z-index: 999;
        white-space: nowrap;
      }
      #toast.show { opacity: 1; }

      /* ── Error ── */
      #screen-error {
        align-items: center; justify-content: center;
        padding: 2rem; text-align: center; gap: 1.25rem;
      }
      .error-icon  { font-size: 4rem; }
      .error-title { font-size: 1.25rem; font-weight: 600; }
      .error-msg   { color: var(--muted); font-size: .9rem; line-height: 1.7; max-width: 300px; white-space: pre-line; }
    </style>
  </head>
  <body>

    <div id="toast"></div>

    <!-- ── Landing ── -->
    <div id="screen-idle" class="screen active">
      <div class="hero-icon">🏍️</div>
      <h1 class="hero-title">Zer0 Touring</h1>
      <p class="hero-sub">出発地と天気をもとに<br/>AIが日帰りコースを3つ提案します</p>

      <div class="loc-toggle">
        <button class="loc-btn active" id="btn-loc-gps">📍 現在地</button>
        <button class="loc-btn" id="btn-loc-manual">✏️ 出発地を入力</button>
