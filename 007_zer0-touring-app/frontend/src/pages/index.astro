---
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="現在地からバイクのツーリングコースをAIが提案" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Zer0 Touring" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta property="og:title" content="Zer0 Touring - AIがツーリングコースを提案" />
    <meta property="og:description" content="現在地と天気をもとにAIが日帰りバイクコースを3つ提案します" />
    <meta property="og:image" content="https://touring.zer0-infra.com/icons/icon-512.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://touring.zer0-infra.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>Zer0 Touring</title>
    <style is:global>
      :root {
        --bg:     #0f172a;
        --card:   #1e2d40;
        --card2:  #243044;
        --text:   #f1f5f9;
        --muted:  #94a3b8;
        --accent: #f97316;
        --border: #2d3f55;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
        min-height: 100svh; -webkit-font-smoothing: antialiased;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-14px); }
      }
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: none; }
      }
      @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
      @keyframes spin { to { transform: rotate(360deg); } }

      .screen { display: none; }
      .screen.active { display: flex; flex-direction: column; min-height: 100svh; animation: fadeIn .3s ease; }

      /* ── Landing ── */
      #screen-idle {
        align-items: center; justify-content: center;
        padding: 2rem; text-align: center; gap: 1.5rem;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(249,115,22,.08) 0%, transparent 70%);
      }
      .hero-icon {
        font-size: 5rem; line-height: 1;
        animation: float 3s ease-in-out infinite;
        filter: drop-shadow(0 8px 24px rgba(249,115,22,.3));
      }
      .hero-title { font-size: 2rem; font-weight: 700; letter-spacing: -.02em; }
      .hero-sub   { color: var(--muted); font-size: .95rem; line-height: 1.7; }
      .usage-badge {
        display: flex; align-items: center; gap: .4rem;
        font-size: .8rem; color: var(--muted);
        background: rgba(255,255,255,.05); border: 1px solid var(--border);
        border-radius: 999px; padding: .25rem .75rem;
        min-height: 1.6rem;
      }
      .usage-badge .dots { display: flex; gap: 4px; }
      .usage-badge .dot  { width: 7px; height: 7px; border-radius: 50%; background: var(--border); transition: background .3s; }
      .usage-badge .dot.used { background: var(--accent); }
      .usage-badge.limit-reached { border-color: #ef4444; color: #ef4444; }

      /* ── Loading ── */
      #screen-loading { align-items: center; justify-content: center; padding: 1.75rem 2rem; gap: 1.75rem; }
      .loading-title  { font-size: 1.2rem; font-weight: 600; }
      .steps { display: flex; flex-direction: column; gap: .65rem; width: 100%; max-width: 320px; }
      .step  {
        display: flex; align-items: center; gap: .875rem;
        color: var(--muted); font-size: .95rem;
        padding: .55rem .75rem; border-radius: .6rem;
        border: 1px solid transparent;
        transition: background .3s, border-color .3s, box-shadow .3s;
      }
      .step.active {
        color: var(--accent);
        background: rgba(249,115,22,.08);
        border-color: rgba(249,115,22,.28);
        animation: step-glow 2s ease-in-out infinite;
      }
      .step.done   {
        color: #22c55e;
        background: rgba(34,197,94,.06);
        border-color: rgba(34,197,94,.2);
      }
      .step-icon   { width: 2rem; text-align: center; font-size: 1.25rem; flex-shrink: 0; }
      .spinner {
        display: inline-block; width: 1.25rem; height: 1.25rem;
        border: 2px solid var(--border); border-top-color: var(--accent);
        border-radius: 50%; animation: spin .7s linear infinite;
      }
      @keyframes step-glow {
        0%,100% { box-shadow: 0 0 10px rgba(249,115,22,.1); }
        50%     { box-shadow: 0 0 22px rgba(249,115,22,.3); }
      }
      .step.done .step-icon { animation: check-pop .4s cubic-bezier(.34,1.56,.64,1); }
      @keyframes check-pop { from { transform: scale(0); } to { transform: scale(1); } }

      /* ── ライディングシーン ── */
      .riding-scene {
        position: relative; width: 100%; max-width: 360px; height: 178px;
        border-radius: 1.25rem; overflow: hidden;
        background: #162b1e;
        box-shadow: 0 8px 32px rgba(0,0,0,.5);
        flex-shrink: 0;
      }
      .rs-sky {
        position: absolute; top:0; left:0; right:0; bottom:44%;
        background: linear-gradient(180deg, #06101e 0%, #0e2444 55%, #7c2d12 100%);
      }
      .rs-star {
        position: absolute; border-radius: 50%;
        background: rgba(255,255,255,.85);
        animation: rs-twinkle 2s ease-in-out infinite;
      }
      .rs-star:nth-child(1){width:2px;height:2px;top:16%;left:10%;animation-duration:2.1s;animation-delay:0s}
      .rs-star:nth-child(2){width:2px;height:2px;top:30%;left:32%;animation-duration:1.8s;animation-delay:.65s}
      .rs-star:nth-child(3){width:2px;height:2px;top:13%;left:58%;animation-duration:2.4s;animation-delay:1.2s}
      .rs-star:nth-child(4){width:2px;height:2px;top:36%;left:78%;animation-duration:2.2s;animation-delay:.9s}
      .rs-star:nth-child(5){width:3px;height:3px;top:22%;left:48%;animation-duration:1.9s;animation-delay:.35s}
      @keyframes rs-twinkle { 0%,100%{opacity:.85} 50%{opacity:.1} }
      .rs-cloud {
        position: absolute; height: 13px;
        background: rgba(255,255,255,.09); border-radius: 9999px;
      }
      .rs-cloud::before,.rs-cloud::after { content:''; position:absolute; background:inherit; border-radius:9999px; }
      .rs-cloud.a { width:52px;top:22%;left:8%; animation:rs-cloud-drift 10s ease-in-out infinite alternate; }
      .rs-cloud.a::before { width:28px;height:22px;top:-10px;left:7px; }
      .rs-cloud.a::after  { width:22px;height:15px;top:-5px;left:28px; }
      .rs-cloud.b { width:40px;top:14%;left:60%; animation:rs-cloud-drift 7s ease-in-out infinite alternate-reverse; }
      .rs-cloud.b::before { width:20px;height:17px;top:-8px;left:6px; }
      .rs-cloud.b::after  { width:17px;height:11px;top:-3px;left:22px; }
      @keyframes rs-cloud-drift { from{transform:translateX(0)} to{transform:translateX(18px)} }
      .rs-mountains {
        position: absolute; bottom:46px; left:0; width:100%; height:72px;
        background: #091525;
        clip-path: polygon(0% 100%,8% 52%,20% 76%,34% 18%,49% 64%,63% 32%,77% 58%,89% 22%,100% 44%,100% 100%);
      }
      .rs-road {
        position: absolute; bottom:0; left:0; width:100%; height:48px;
        background: #1f2937;
      }
      .rs-road::before { content:''; position:absolute; top:0;left:0;width:100%;height:2px; background:rgba(255,255,255,.06); }
      .rs-dashes {
        position: absolute; top:50%; left:0; width:200%; height:3px;
        background: repeating-linear-gradient(to right, rgba(249,115,22,.75) 0, rgba(249,115,22,.75) 26px, transparent 26px, transparent 52px);
        animation: rs-dashes 1.1s linear infinite;
      }
      @keyframes rs-dashes { to { transform: translateX(-52px); } }
      .rs-bike {
        position: absolute; bottom:52px; left:50%;
        transform: translateX(-50%) scaleX(-1);
        font-size: 2.5rem; z-index:4;
        filter: drop-shadow(0 4px 12px rgba(0,0,0,.7));
        animation: rs-bounce .28s ease-in-out infinite alternate;
      }
      @keyframes rs-bounce {
        from { transform: translateX(-50%) scaleX(-1) translateY(0); }
        to   { transform: translateX(-50%) scaleX(-1) translateY(-5px); }
      }
      .rs-exhaust {
        position: absolute; bottom:60px; left:calc(50% - 42px);
        display:flex; gap:5px; align-items:center;
      }
      .rs-puff {
        border-radius: 50%; background: rgba(200,200,200,.22);
        animation: rs-puff 1.4s ease-out infinite;
      }
      .rs-puff:nth-child(1){width:6px;height:6px;animation-delay:0s}
      .rs-puff:nth-child(2){width:8px;height:8px;animation-delay:.47s}
      .rs-puff:nth-child(3){width:5px;height:5px;animation-delay:.94s}
      @keyframes rs-puff {
        0%  { opacity:.5; transform: translateX(0)    scale(1); }
        100%{ opacity:0;  transform: translateX(-18px) scale(2.2); }
      }

      /* ── ローディングドット ── */
      .loading-dots span { opacity:0; animation: ld-dot 1.5s step-end infinite; }
      .loading-dots span:nth-child(1){animation-delay:0s}
      .loading-dots span:nth-child(2){animation-delay:.5s}
      .loading-dots span:nth-child(3){animation-delay:1s}
      @keyframes ld-dot { 0%,49%{opacity:0} 50%,100%{opacity:1} }

      /* ── ボタン ── */
      .btn-primary {
        background: var(--accent); color: #fff; border: none;
        border-radius: 9999px; padding: 1rem 0; font-size: 1.125rem;
        font-weight: 600; cursor: pointer; width: 100%; max-width: 320px;
        transition: opacity .15s, transform .1s;
        box-shadow: 0 4px 20px rgba(249,115,22,.35);
      }
      .btn-primary:active { opacity: .75; transform: scale(.97); }
      .btn-outline {
        background: transparent; color: var(--accent);
        border: 1.5px solid var(--accent); border-radius: 9999px;
        padding: .5rem 1.25rem; font-size: .875rem; font-weight: 500;
        cursor: pointer; white-space: nowrap; transition: background .15s;
      }
      .btn-outline:hover { background: rgba(249,115,22,.1); }
      .btn-ghost {
        background: transparent; color: var(--muted);
        border: 1.5px solid var(--border); border-radius: 9999px;
        padding: .5rem 1.25rem; font-size: .875rem; font-weight: 500;
        cursor: pointer; white-space: nowrap; transition: border-color .15s, color .15s;
      }
      .btn-ghost:hover { border-color: var(--muted); color: var(--text); }

      /* ── topbar ── */
      .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: .875rem 1.5rem; border-bottom: 1px solid var(--border);
        position: sticky; top: 0; background: var(--bg); z-index: 10; width: 100%;
      }
      .topbar-left  { display: flex; flex-direction: column; gap: .15rem; flex: 1; }
      .topbar-title { font-size: 1.1rem; font-weight: 700; }
      .weather-subtitle {
        display: none;
        font-size: .8rem; font-weight: 600; color: #93c5fd;
        background: rgba(147,197,253,.1); border: 1px solid rgba(147,197,253,.22);
        border-radius: 9999px; padding: .16rem .65rem; align-self: flex-start;
      }
      .topbar-btns  { display: flex; gap: .5rem; }

      /* ════════════════════════════════════════
         スワイプカードスライダー
         overflow:hidden + translateX で確実に動作
      ════════════════════════════════════════ */
      #screen-results { align-items: center; }

      .slider-outer {
        width: 100%; max-width: 560px;
        padding: 1.25rem 1.5rem 0;
        animation: slideUp .5s ease both;
      }
      @media (max-width: 679px) {
        .slider-outer { padding: 1rem .875rem 0; }
      }

      .slider-dots {
        display: flex; justify-content: center; gap: .6rem;
        margin-bottom: .875rem;
      }
      .dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--border); cursor: pointer; border: none; padding: 0;
        transition: background .25s, transform .25s;
      }
      .dot.active { background: var(--accent); transform: scale(1.4); }

      /* scroll-snap スライダー本体 */
      .card-viewport {
        display: flex;
        overflow-x: scroll;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        border-radius: .875rem;
        border: 1px solid var(--border);
        width: 100%;
      }
      .card-viewport::-webkit-scrollbar { display: none; }

      /* ─── コースカード ─── */
      .course-card {
        flex: 0 0 100%;
        scroll-snap-align: start;
        background: var(--card);
        display: flex; flex-direction: column;
        -webkit-tap-highlight-color: transparent;
        min-width: 0;
      }

      /* カードヘッダー（景色シルエット背景） */
      .card-header {
        width: 100%; height: 130px; position: relative; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; z-index: 0;
      }
      .card-header-icon {
        font-size: 2.75rem; position: relative; z-index: 2;
        filter: drop-shadow(0 4px 16px rgba(0,0,0,.55));
        animation: float 3.5s ease-in-out infinite;
      }
      .card-header-badges {
        position: absolute; bottom: .75rem; left: .875rem; z-index: 2;
        display: flex; gap: .4rem;
      }
      /* アニメーションオーバーレイ（シマーのみ） */
      .card-header-anim {
        position: absolute; inset: 0; pointer-events: none; z-index: 1;
      }
      .card-header-anim::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(
          110deg,
          transparent 20%,
          rgba(255,255,255,.04) 44%,
          rgba(255,255,255,.08) 50%,
          rgba(255,255,255,.04) 56%,
          transparent 80%
        );
        background-size: 250% 100%;
        animation: ch-shimmer 5s ease-in-out infinite;
      }
      @keyframes ch-shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }

      /* ── 景色シルエット（近距離: 丘と木々） ── */
      .card-header.ch-near {
        background: linear-gradient(180deg, #051a0c 0%, #0e3318 45%, #184e24 100%);
      }
      .card-header.ch-near::after {
        content: ''; position: absolute;
        bottom: 0; left: 0; width: 100%; height: 82px; z-index: 0;
        background: #041008;
        clip-path: polygon(
          0% 100%, 0% 56%,
          4% 48%, 9% 58%, 14% 42%, 20% 54%,
          25% 36%, 30% 46%, 35% 32%, 39% 40%, 44% 52%,
          50% 36%, 56% 48%, 61% 30%, 66% 42%, 70% 54%,
          75% 40%, 80% 52%, 86% 36%, 91% 48%, 96% 42%,
          100% 50%, 100% 100%
        );
      }

      /* ── 景色シルエット（中距離: 海と水平線） ── */
      .card-header.ch-mid {
        background: linear-gradient(180deg, #04101e 0%, #091e3c 40%, #0f2e56 70%, #0b2444 100%);
      }
      .card-header.ch-mid::before {
        content: ''; position: absolute;
        left: 0; right: 0; bottom: 52px; height: 20px; z-index: 0;
        background: linear-gradient(180deg, transparent, rgba(56,189,248,.12), transparent);
      }
      .card-header.ch-mid::after {
        content: ''; position: absolute;
        bottom: 0; left: 0; width: 100%; height: 58px; z-index: 0;
        background: linear-gradient(180deg, #061630 0%, #041028 100%);
        clip-path: polygon(
          0% 100%, 0% 38%,
          8% 32%, 16% 42%, 24% 28%, 32% 38%,
          40% 22%, 50% 34%, 60% 24%, 68% 36%,
          76% 28%, 84% 38%, 92% 30%, 100% 36%,
          100% 100%
        );
      }

      /* ── 景色シルエット（長距離: 険しい山脈） ── */
      .card-header.ch-far {
        background: linear-gradient(180deg, #150422 0%, #330a50 30%, #5e1480 58%, #22073c 100%);
      }
      .card-header.ch-far::before {
        content: ''; position: absolute;
        bottom: 0; left: 0; width: 100%; height: 78px; z-index: 0;
        background: #1a063a;
        clip-path: polygon(
          0% 100%, 0% 60%,
          7% 42%, 14% 58%, 22% 28%, 30% 52%,
          38% 20%, 46% 55%, 54% 32%, 62% 58%,
          70% 38%, 78% 60%, 86% 44%, 93% 58%,
          100% 48%, 100% 100%
        );
      }
      .card-header.ch-far::after {
        content: ''; position: absolute;
        bottom: 0; left: 0; width: 100%; height: 65px; z-index: 0;
        background: #0a0118;
        clip-path: polygon(
          0% 100%, 0% 65%,
          5% 50%, 11% 65%, 18% 38%, 25% 60%,
          32% 18%, 40% 58%, 48% 12%, 55% 55%,
          62% 30%, 70% 60%, 76% 42%, 82% 62%,
          88% 48%, 94% 62%, 100% 52%, 100% 100%
        );
      }

      /* ── 準備シーン ── */
      .card-header-prep {
        position: absolute; top: .6rem; left: 0; right: 0;
        display: flex; align-items: center; justify-content: center;
        pointer-events: none; z-index: 1;
      }
      .prep-row { display: flex; gap: .6rem; align-items: center; }
      .prep-step {
        display: flex; align-items: center; gap: .2rem;
        opacity: 0;
        animation: prep-step 7s ease-in-out infinite;
      }
      .prep-step.s1 { animation-delay: 0s; }
      .prep-step.s2 { animation-delay: .65s; }
      .prep-step.s3 { animation-delay: 1.3s; }
      .prep-step .pe { font-size: 1.15rem; line-height: 1; }
      .prep-ok {
        font-size: .6rem; font-weight: 900; color: #4ade80; line-height: 1;
        text-shadow: 0 0 6px rgba(74,222,128,.6);
      }
      @keyframes prep-step {
        0%   { opacity: 0; transform: translateY(-8px) scale(.85); }
        8%   { opacity: 1; transform: translateY(0)   scale(1); }
        55%  { opacity: 1; transform: translateY(0)   scale(1); }
        65%  { opacity: 0; transform: translateY(-6px) scale(.9); }
        100% { opacity: 0; transform: translateY(-8px) scale(.85); }
      }
      .prep-go-label {
        position: absolute; right: .85rem;
        font-size: .68rem; font-weight: 900; letter-spacing: .16em;
        color: #fff;
        text-shadow: 0 0 12px rgba(255,255,255,.8), 0 0 24px rgba(249,115,22,.6);
        opacity: 0;
        animation: prep-go 7s ease-in-out infinite;
      }
      @keyframes prep-go {
        0%,  40% { opacity: 0; transform: scale(.5) translateX(-4px); }
        50%, 64% { opacity: 1; transform: scale(1)   translateX(0); }
        74%      { opacity: 0; transform: scale(1.2)  translateX(14px); }
        100%     { opacity: 0; transform: scale(.5)  translateX(-4px); }
      }

      /* 情報エリア */
      .card-body {
        padding: 1.1rem 1.25rem .875rem;
        display: flex; flex-direction: column; gap: .55rem; flex: 1;
      }
      .card-name { font-size: 1.2rem; font-weight: 700; line-height: 1.3; }
      .course-tags { display: flex; gap: .3rem; flex-wrap: wrap; }
      .course-tag {
        font-size: .75rem; font-weight: 600;
        background: rgba(255,255,255,.08); color: rgba(255,255,255,.85);
        border-radius: 9999px; padding: .18rem .58rem;
      }
      .card-info-row {
        display: flex; align-items: center; gap: .45rem;
        font-size: .83rem; color: var(--muted); flex-wrap: wrap;
      }
      .card-info-sep { color: var(--border); user-select: none; }
      .route-summary {
        font-size: .8rem; color: rgba(255,255,255,.6);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      }


      /* アクションボタン */
      .card-actions {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: .75rem; padding: .875rem 1.25rem;
        border-top: 1px solid var(--border);
      }
      .card-btn-nav {
        display: flex; align-items: center; justify-content: center; gap: .35rem;
        border: 1px solid rgba(249,115,22,.45);
        background: rgba(249,115,22,.12); color: var(--accent);
        border-radius: .6rem; padding: .75rem;
        font-size: .88rem; font-weight: 600; cursor: pointer; transition: background .15s;
      }
      .card-btn-nav:hover { background: rgba(249,115,22,.22); }
      .card-btn-detail {
        display: flex; align-items: center; justify-content: center;
        border: none; background: var(--card2); color: var(--text);
        border-radius: .6rem; padding: .75rem;
        font-size: .88rem; font-weight: 600; cursor: pointer; transition: background .15s;
      }
      .card-btn-detail:hover { background: var(--border); }

      /* バッジ */
      .dist-tag {
        font-size: .72rem; font-weight: 700; border-radius: .35rem;
        padding: .22rem .65rem; display: inline-flex; align-items: center; gap: .25rem;
      }
      .dist-near { background: rgba(34,197,94,.2);  color: #4ade80; border: 1px solid rgba(34,197,94,.4); }
      .dist-mid  { background: rgba(56,189,248,.2);  color: #7dd3fc; border: 1px solid rgba(56,189,248,.4); }
      .dist-far  { background: rgba(168,85,247,.2);  color: #c4b5fd; border: 1px solid rgba(168,85,247,.4); }

      .dest-weather-badge {
        font-size: .72rem; font-weight: 700; color: #e0f2fe;
        background: rgba(0,0,0,.48); border-radius: .35rem;
        padding: .22rem .6rem; backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,.15);
      }

      /* ════════════════════════════════════════
         天気比較ウィジェット（詳細画面・画像直下）
      ════════════════════════════════════════ */
      .weather-compare {
        width: 100%; max-width: 680px;
        display: none; flex-shrink: 0;
        background: var(--card2); border-bottom: 1px solid var(--border);
      }
      .weather-compare.visible { display: flex; }
      .wc-side {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; padding: 1rem .75rem; gap: .28rem;
      }
      .wc-label {
        font-size: .62rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .06em;
      }
      .wc-icon { font-size: 1.8rem; line-height: 1; }
      .wc-temp { font-size: 1.3rem; font-weight: 700; }
      .wc-cond { font-size: .72rem; color: var(--muted); text-align: center; }
      .wc-arrow {
        position: relative;
        display: flex; align-items: center; justify-content: center;
        width: 80px; flex-shrink: 0; overflow: hidden;
      }
      .wc-road {
        position: absolute; width: 100%; height: 1.5px;
        background: repeating-linear-gradient(
          to right,
          var(--border) 0, var(--border) 5px,
          transparent 5px, transparent 10px
        );
      }
      .wc-bike {
        position: relative; font-size: 1.15rem; z-index: 1;
        animation: bike-ride 4s ease-in-out infinite;
      }
      @keyframes bike-ride {
        0%   { transform: translateX(-36px) scaleX(-1); opacity: 0; }
        8%   { transform: translateX(-36px) scaleX(-1); opacity: 1; }
        80%  { transform: translateX(36px)  scaleX(-1); opacity: 1; }
        93%  { transform: translateX(36px)  scaleX(-1); opacity: 0; }
        100% { transform: translateX(-36px) scaleX(-1); opacity: 0; }
      }

      @media (max-width: 679px) {
        .topbar { padding: .6rem 1rem; }
        .card-name { font-size: 1.1rem; }
      }

      /* ════════════════════════════════════════
         週間天気予報
      ════════════════════════════════════════ */
      #forecast-wrap {
        width: 100%; max-width: 560px;
        padding: 1.25rem 1.5rem 2rem; display: none;
      }
      @media (max-width: 679px) { #forecast-wrap { padding: 1rem .875rem 1.5rem; } }
      .forecast-label {
        font-size: .68rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .06em;
        border-bottom: 1px solid var(--border);
        padding-bottom: .4rem; margin-bottom: .65rem;
      }
      .forecast-strip {
        display: flex; gap: .5rem;
        overflow-x: auto; padding-bottom: .4rem;
        scrollbar-width: thin; scrollbar-color: var(--border) transparent;
      }
      .forecast-strip::-webkit-scrollbar { height: 4px; }
      .forecast-strip::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
      .forecast-day {
        display: flex; flex-direction: column; align-items: center;
        gap: .22rem; flex-shrink: 0; min-width: 60px;
        background: var(--card2); border: 1px solid var(--border);
        border-radius: .65rem; padding: .55rem .6rem; font-size: .7rem;
      }
      .forecast-day.today { border-color: rgba(56,189,248,.5); background: rgba(56,189,248,.06); }
      .forecast-day.best  { border-color: rgba(249,115,22,.6); background: rgba(249,115,22,.1); }
      .fd-dow  { font-size: .65rem; font-weight: 700; color: var(--muted); }
      .fd-icon { font-size: 1.3rem; line-height: 1; }
      .fd-temp { font-weight: 700; }
      .fd-temp-min { font-size: .62rem; color: var(--muted); }
      .fd-best { font-size: .6rem; font-weight: 700; color: var(--accent); white-space: nowrap; }
      .fd-score { display: flex; gap: 2px; }
      .fd-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--border); }
      .fd-dot.on { background: var(--accent); }

      /* ── 詳細画面コースナビ ── */
      .detail-nav { display: flex; align-items: center; gap: .3rem; }
      .detail-nav-label {
        font-size: .78rem; color: var(--muted);
        min-width: 2.8em; text-align: center; font-variant-numeric: tabular-nums;
      }
      .detail-nav-btn {
        background: var(--card2); border: 1px solid var(--border); color: var(--text);
        border-radius: .4rem; width: 1.9rem; height: 1.9rem;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem; cursor: pointer;
        transition: background .15s, opacity .15s;
      }
      .detail-nav-btn:disabled { opacity: .28; cursor: default; pointer-events: none; }
      .detail-nav-btn:not(:disabled):hover { background: var(--border); }

      /* ════════════════════════════════════════
         コース詳細
      ════════════════════════════════════════ */
      #screen-detail { overflow-y: auto; align-items: center; }
      #screen-detail > .topbar,
      #screen-detail > .detail-img-wrap,
      #screen-detail > .weather-compare,
      #screen-detail > .detail-content { width: 100%; max-width: 680px; }

      .detail-img-wrap {
        width: 100%; height: 160px; overflow: hidden; flex-shrink: 0;
        background: var(--card2); position: relative;
      }
      .detail-img-ph {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: .4rem;
      }
      .detail-img {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; opacity: 0; transition: opacity .4s;
      }
      .detail-img.loaded { opacity: 1; }
      .detail-content {
        display: flex; flex-direction: column; gap: 1.5rem;
        padding: 1.5rem 1.25rem 2.5rem; flex: 1;
      }
      .detail-header { display: flex; flex-direction: column; gap: .65rem; }
      .detail-tag-row { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
      .detail-name { font-size: 1.5rem; font-weight: 700; line-height: 1.3; }
      .detail-meta { display: flex; gap: .4rem; flex-wrap: wrap; }
      .meta-pill-lg {
        font-size: .82rem; color: var(--muted);
        background: var(--card2); border-radius: 9999px; padding: .25rem .75rem;
      }
      .section { display: flex; flex-direction: column; gap: .6rem; }
      .section-title {
        font-size: .68rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .06em;
        border-bottom: 1px solid var(--border); padding-bottom: .4rem;
      }
