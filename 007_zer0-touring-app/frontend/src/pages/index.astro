    <!-- ── Error ── -->
    <div id="screen-error" class="screen">
      <span class="error-icon" id="error-icon">⚠️</span>
      <h2 class="error-title" id="error-title">エラーが発生しました</h2>
      <p class="error-msg" id="error-msg"></p>
      <button class="btn-primary" id="btn-error-retry">もう一度試す</button>
    </div>

    <script>
      const API_BASE = import.meta.env.PUBLIC_API_URL ?? '';

      // localStorage に adminToken があれば全リクエストに付与
      function apiHeaders(extra = {}) {
        const token = localStorage.getItem('adminToken') ?? '';
        const h = { 'Content-Type': 'application/json', ...extra };
        if (token) h['X-Admin-Token'] = token;
        return h;
      }

      const WEATHER = {
        0:'晴れ',1:'晴れのち曇り',2:'曇り',3:'曇り',45:'霧',48:'霧',
        51:'小雨',53:'雨',55:'大雨',61:'小雨',63:'雨',65:'大雨',
        71:'小雪',73:'雪',75:'大雪',77:'雪',80:'にわか雨',81:'にわか雨',
        82:'にわか大雨',85:'にわか雪',86:'にわか大雪',95:'雷雨',96:'雷雨',99:'激しい雷雨',
      };
      const DIST = [
        { label:'近距離コース', icon:'🌿', cls:'dist-near', bgCls:'ch-near', phGrad:'linear-gradient(160deg,#051a0c,#184e24)' },
        { label:'中距離コース', icon:'🌊', cls:'dist-mid',  bgCls:'ch-mid',  phGrad:'linear-gradient(160deg,#04101e,#0f2e56)' },
        { label:'長距離コース', icon:'🏔', cls:'dist-far',  bgCls:'ch-far',  phGrad:'linear-gradient(160deg,#150422,#5e1480)' },
      ];
      const ROAD = { '峠道':'🏔','山道':'🏔','高速道路':'🛣','国道':'🚗','一般道':'🚗','県道':'🛤','海岸線':'🌊' };
      const SPOT = { '道の駅':'🏪','温泉':'♨️','展望台':'🔭','カフェ':'☕','食事処':'🍜','観光地':'📸','ガソリンスタンド':'⛽' };

      function escHtml(s) {
        return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function fmtHours(h) {
        const rounded = Math.ceil(Math.round(h * 60) / 10) * 10;  // 10分単位で切り上げ
        const hrs = Math.floor(rounded / 60);
        const mins = rounded % 60;
        if (hrs === 0) return `約${mins}分`;
        if (mins === 0) return `約${hrs}時間`;
        return `約${hrs}時間${mins}分`;
      }

      let courses     = [];
      let userLat     = null, userLon = null;
      let weatherMeta = { icon:'☀️', score:5, label:'絶好の日和！', temp:'--' };
      let currentSlide = 0;
      let sliderListenerAdded = false;
      let destForecastController = null;
      let locationMode = 'gps';
      let selectedPrefs = new Set();
      let originDisplayName = '現在地';
      let remainingUses = null;
      let shortUrlCache = {}; // courseIdx → short URL
      let detailCourseIdx = 0;

      /* ── 天気ヘルパー ── */
      function getWeatherMeta(code) {
        if (code === 0)                 return { icon:'☀️', score:5, label:'絶好の日和！' };
        if (code <= 2)                  return { icon:'🌤', score:4, label:'ツーリング向き' };
        if (code === 3)                 return { icon:'☁️', score:3, label:'まずまず' };
        if (code===45 || code===48)     return { icon:'🌫', score:2, label:'視界に注意' };
        if (code>=51 && code<=67)       return { icon:'🌧', score:1, label:'雨天注意' };
        if (code>=71 && code<=77)       return { icon:'🌨', score:1, label:'降雪注意' };
        if (code>=80 && code<=82)       return { icon:'🌦', score:2, label:'にわか雨注意' };
        if (code>=95)                   return { icon:'⛈', score:0, label:'走行危険' };
        return { icon:'🌤', score:3, label:'まずまず' };
      }
      function renderWeatherInfo() {
        const el = document.getElementById('weather-subtitle');
        if (!el) return;
        el.textContent = `📍${originDisplayName}  ${weatherMeta.icon} ${weatherMeta.temp}℃ · ${weatherMeta.label}`;
        el.style.display = 'inline-flex';
      }

      async function geocodeOrigin(input) {
        const params = new URLSearchParams({ q: input, format: 'json', limit: 1, countrycodes: 'jp', 'accept-language': 'ja' });
        const res = await fetch(`https://nominatim.openstreetmap.org/search?${params.toString()}`);
        if (!res.ok) throw new Error('network error');
        const data = await res.json();
        if (!data || data.length === 0) throw new Error('not found');
        return { lat: parseFloat(data[0].lat), lon: parseFloat(data[0].lon) };
      }
      async function renderForecastInto(lat, lon, stripEl, signal) {
        try {
          const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=weathercode,temperature_2m_max,temperature_2m_min&timezone=auto&forecast_days=7`, signal ? { signal } : {});
          const d = await res.json();
          const { time, weathercode, temperature_2m_max, temperature_2m_min } = d.daily;
          let bestIdx=1, bestScore=-1;
          weathercode.forEach((c,i)=>{if(i===0)return;const s=getWeatherMeta(c).score;if(s>bestScore){bestScore=s;bestIdx=i;}});
          const DOW=['日','月','火','水','木','金','土'];
          stripEl.innerHTML=time.map((t,i)=>{
            const date=new Date(t+'T00:00:00');
            const meta=getWeatherMeta(weathercode[i]);
            const tMax=Math.round(temperature_2m_max[i]);
            const tMin=Math.round(temperature_2m_min[i]);
            const dots=Array.from({length:5},(_,di)=>`<span class="fd-dot${di<meta.score?' on':''}"></span>`).join('');
            return `<div class="forecast-day${i===0?' today':''}${i===bestIdx?' best':''}">
              <span class="fd-dow">${i===0?'今日':DOW[date.getDay()]}</span>
              <span class="fd-icon">${meta.icon}</span>
              <span class="fd-temp">${tMax}℃</span>
              <span class="fd-temp-min">${tMin}℃</span>
              <div class="fd-score">${dots}</div>
              ${i===bestIdx?'<span class="fd-best">★ 狙い目</span>':''}
            </div>`;
          }).join('');
        } catch(e) { if (e.name !== 'AbortError') console.warn('[forecast]', e); }
      }
      async function renderForecast(lat, lon) {
        const strip=document.getElementById('forecast-strip');
        const wrap=document.getElementById('forecast-wrap');
        if(!strip||!wrap)return;
        await renderForecastInto(lat, lon, strip);
        if(strip.innerHTML) wrap.style.display='block';
      }

      /* ─────────────────────────────────────
         スライダー
         showScreen の後に initSlider() を呼ぶことで
         clientWidth が正しく取れる
      ───────────────────────────────────── */
      function updateDots() {
        document.querySelectorAll('.dot').forEach((dot,i)=>{
          dot.classList.toggle('active', i===currentSlide);
        });
      }

      function goTo(idx) {
        const vp = document.getElementById('card-viewport');
        currentSlide = Math.max(0, Math.min(idx, courses.length-1));
        vp.scrollTo({ left: currentSlide * vp.clientWidth, behavior: 'smooth' });
        updateDots();
      }

      function initSlider() {
        const vp = document.getElementById('card-viewport');
        vp.scrollLeft = 0;
        currentSlide  = 0;
        if (sliderListenerAdded) return;
        sliderListenerAdded = true;
        vp.addEventListener('scroll', () => {
          if (!vp.clientWidth) return;
          const idx = Math.round(vp.scrollLeft / vp.clientWidth);
          if (idx !== currentSlide) { currentSlide = idx; updateDots(); }
        }, { passive: true });
      }

      function renderSlider(data) {
        courses = [...data.courses].sort((a,b)=>(a.distance_km??0)-(b.distance_km??0)).slice(0,3);
        currentSlide = 0;

        const vp     = document.getElementById('card-viewport');
        const dotsEl = document.getElementById('slider-dots');

        vp.innerHTML = courses.map((c,i) => {
          const d = DIST[i];
          const firstSpot = (c.outbound_spots ?? c.rest_spots ?? [])[0];
          const routeLine = firstSpot
            ? `📍 現在地 → ${escHtml(firstSpot.name)} → ${escHtml(c.destination)}`
            : `📍 現在地 → ${escHtml(c.destination)}`;
          const tagsHtml = (c.tags??[]).slice(0,3).map(t=>`<span class="course-tag">${escHtml(t)}</span>`).join('');
          const destWeatherBadge = c.dest_weather_code !== undefined
            ? (() => { const m = getWeatherMeta(c.dest_weather_code); return `<span class="dest-weather-badge">📌 ${m.icon} ${c.dest_temp}℃</span>`; })()
            : '';
          return `
            <article class="course-card" data-idx="${i}">
              <div class="card-header ${d.bgCls}">
                <div class="card-header-anim"></div>
                <div class="card-header-prep">
                  <div class="prep-row">
                    <span class="prep-step s1"><span class="pe">🪖</span><span class="prep-ok">✓</span></span>
                    <span class="prep-step s2"><span class="pe">🧤</span><span class="prep-ok">✓</span></span>
                    <span class="prep-step s3"><span class="pe">🗺️</span><span class="prep-ok">✓</span></span>
                  </div>
                  <span class="prep-go-label">GO!</span>
                </div>
                <span class="card-header-icon">🏍️</span>
                <div class="card-header-badges">
                  <span class="dist-tag ${d.cls}">${d.icon} ${d.label}</span>
                  ${destWeatherBadge}
                </div>
              </div>
              <div class="card-body">
                <h3 class="card-name">${escHtml(c.name)}</h3>
                <p class="route-summary">${routeLine}</p>
                ${tagsHtml?`<div class="course-tags">${tagsHtml}</div>`:''}
                <div class="card-info-row">
                  <span>🛣 ${c.distance_km}km</span>
                  <span class="card-info-sep">·</span>
                  <span>⏱ 片道${fmtHours(c.duration_hours)}</span>
                  <span class="card-info-sep">·</span>
                  <span>🏁 ${escHtml(c.destination)}</span>
                </div>
              </div>
              <div class="card-actions">
                <button class="card-btn-nav">🗺 ナビ開始</button>
                <button class="card-btn-detail">詳細を見る →</button>
              </div>
            </article>`;
        }).join('');

        // ボタンイベント
        vp.querySelectorAll('.course-card').forEach(card => {
          card.querySelector('.card-btn-detail').addEventListener('click',()=>openDetail(+card.dataset.idx));
          card.querySelector('.card-btn-nav').addEventListener('click',()=>{
            window.open(buildMapUrl(courses[+card.dataset.idx]), '_blank', 'noopener,noreferrer');
          });
        });

        // ドット
        dotsEl.innerHTML = courses.map((_,i)=>
          `<button class="dot${i===0?' active':''}" data-i="${i}" aria-label="コース${i+1}"></button>`
        ).join('');
        dotsEl.querySelectorAll('.dot').forEach(dot=>{
          dot.addEventListener('click',()=>goTo(+dot.dataset.i));
        });
        // ← initSlider() は showScreen() の後に呼ぶ
      }

      /* ── スクリーン ── */
      function showScreen(id) {
        document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        window.scrollTo(0,0);
      }

      const SICONS={'step-gps':'📍','step-weather':'🌤','step-ai':'🤖'};
      const SIIDS ={'step-gps':'icon-gps','step-weather':'icon-weather','step-ai':'icon-ai'};
      function setStep(id,state){
        const el=document.getElementById(id);
        const ic=document.getElementById(SIIDS[id]);
        el.className='step'+(state==='active'?' active':state==='done'?' done':'');
        if(state==='active') ic.innerHTML='<span class="spinner"></span>';
        else if(state==='done') ic.textContent='✅';
        else ic.textContent=SICONS[id];
      }

      async function loadPhoto(spot,imgEl){
        if(!imgEl||!spot)return;
        try{
          const res=await fetch('https://ja.wikipedia.org/api/rest_v1/page/summary/'+encodeURIComponent(spot));
          const data=await res.json();
          const src=data.thumbnail?.source;
          if(!src)return;
          imgEl.onload=()=>imgEl.classList.add('loaded');
          imgEl.onerror=()=>{imgEl.src='';imgEl.classList.remove('loaded');};
          imgEl.src=src.replace(/\/\d+px-/,'/1280px-');
        }catch(_){imgEl.src='';}
      }

      function buildMapUrl(c){
        const dest  = c.dest_lat&&c.dest_lon
          ? `${c.dest_lat},${c.dest_lon}`
          : encodeURIComponent(c.destination);
        const spots = (c.outbound_spots ?? c.rest_spots ?? []).map(s=>
          s.lat&&s.lon ? `${s.lat},${s.lon}` : encodeURIComponent(s.name)
        );
        const hasGps = userLat&&userLon;
        const coord  = hasGps?`${userLat.toFixed(6)},${userLon.toFixed(6)}`:'';
        const op = hasGps?`&origin=${coord}`:'';
        const wp = spots.length?`&waypoints=${spots.join('%7C')}` :'';
        return `https://www.google.com/maps/dir/?api=1${op}&destination=${dest}${wp}&travelmode=driving`;
      }

      function openDetail(idx){
        detailCourseIdx = idx;
        // 詳細画面を開くたびに先頭へスクロール
        const detailEl=document.getElementById('screen-detail');
        if(detailEl) detailEl.scrollTop=0;

        const c=courses[idx];
        const d=DIST[c._distIdx??idx];

        // コースナビ（前後ボタン・インジケーター）
        const navEl=document.getElementById('detail-nav');
        const prevBtn=document.getElementById('btn-detail-prev');
        const nextBtn=document.getElementById('btn-detail-next');
        const navLabel=document.getElementById('detail-nav-label');
        if(navEl)  navEl.style.display = courses.length>1 ? 'flex' : 'none';
        if(navLabel) navLabel.textContent=`${idx+1} / ${courses.length}`;
        if(prevBtn){ prevBtn.disabled=idx===0; prevBtn.onclick=()=>openDetail(idx-1); }
        if(nextBtn){ nextBtn.disabled=idx===courses.length-1; nextBtn.onclick=()=>openDetail(idx+1); }
        const ph=document.getElementById('detail-img-ph');
        ph.style.background=d.phGrad;
        ph.innerHTML=`<span style="font-size:2.2rem;filter:drop-shadow(0 4px 12px rgba(0,0,0,.5))">🏍️</span>`;
        const dimg=document.getElementById('detail-img');
        dimg.classList.remove('loaded');dimg.src='';
        loadPhoto(c.photo_spot,dimg);
        document.getElementById('detail-tags').innerHTML=
          `<span class="dist-tag ${d.cls}">${d.icon} ${d.label}</span>`;
        document.getElementById('detail-name').textContent=c.name;
        const rh=c.return_hours??c.duration_hours;
        document.getElementById('detail-meta').innerHTML=
          `<span class="meta-pill-lg">🛣 ${c.distance_km}km</span>`+
          `<span class="meta-pill-lg">⏱ 片道 ${fmtHours(c.duration_hours)}</span>`+
          `<span class="meta-pill-lg">🔄 往復 ${fmtHours(c.duration_hours+rh)}</span>`+
          `<span class="meta-pill-lg">🏁 ${escHtml(c.destination)}</span>`;
        document.getElementById('detail-highlights').innerHTML=(c.highlights??[]).map(h=>`<li>${escHtml(h)}</li>`).join('');
        document.getElementById('detail-roads').innerHTML=(c.road_types??[]).map(r=>`<span class="road-tag-lg">${ROAD[r]??'🚗'} ${escHtml(r)}</span>`).join('');
        const spotHtml = spots => (spots??[]).map(s=>
          `<div class="spot-item"><span class="spot-icon">${SPOT[s.type]??'📌'}</span><span class="spot-name">${escHtml(s.name)}</span><span class="spot-type">${escHtml(s.type)}</span></div>`
        ).join('');
        const outboundSpots = c.outbound_spots ?? c.rest_spots ?? [];
        const returnSpots   = c.return_spots ?? [];
        document.getElementById('detail-outbound-spots').innerHTML = spotHtml(outboundSpots);
        document.getElementById('detail-return-spots').innerHTML   = spotHtml(returnSpots);
        document.getElementById('detail-outbound-section').style.display = outboundSpots.length ? '' : 'none';
        document.getElementById('detail-return-section').style.display   = returnSpots.length   ? '' : 'none';
        document.getElementById('detail-info').innerHTML=[
          c.return_note?`<div class="info-chip info-return"><span>🔄</span><span>帰路: ${escHtml(c.return_note)}</span></div>`:'',
          c.caution    ?`<div class="info-chip info-caution"><span>⚠️</span><span>${escHtml(c.caution)}</span></div>`:'',
          c.best_season?`<div class="info-chip info-season"><span>🌸</span><span>ベストシーズン: ${escHtml(c.best_season)}</span></div>`:'',
        ].filter(Boolean).join('');

        // 現在地 vs 目的地 天気比較ウィジェット
        const compareEl=document.getElementById('detail-weather-compare');
        const wcCurrent=document.getElementById('wc-current');
        const wcDest=document.getElementById('wc-dest');
        const hasCurrentWeather = weatherMeta.temp !== '--';
        const hasDestWeather = c.dest_weather_code !== undefined;
        if(compareEl && (hasCurrentWeather || hasDestWeather)){
          if(wcCurrent){
            if(hasCurrentWeather){
              wcCurrent.innerHTML=`<span class="wc-label">📍現在地</span><span class="wc-icon">${weatherMeta.icon}</span><span class="wc-temp">${weatherMeta.temp}℃</span><span class="wc-cond">${weatherMeta.label}</span>`;
            }else{
              wcCurrent.innerHTML=`<span class="wc-label">📍現在地</span><span class="wc-icon">--</span>`;
            }
          }
          if(wcDest){
            if(hasDestWeather){
              const dm=getWeatherMeta(c.dest_weather_code);
              wcDest.innerHTML=`<span class="wc-label">📌目的地</span><span class="wc-icon">${dm.icon}</span><span class="wc-temp">${c.dest_temp}℃</span><span class="wc-cond">${dm.label}</span>`;
            }else{
              wcDest.innerHTML=`<span class="wc-label">📌目的地</span><span class="wc-icon" style="font-size:1rem;color:var(--muted)">取得中...</span>`;
            }
          }
          compareEl.classList.add('visible');
        }else if(compareEl){
          compareEl.classList.remove('visible');
        }

        // 目的地の7日間予報（prev/next 高速タップ時の古いレスポンス上書きをキャンセル）
        if (destForecastController) destForecastController.abort();
        destForecastController = null;
        const destSection=document.getElementById('detail-dest-weather-section');
        const destForecastStrip=document.getElementById('detail-dest-forecast-strip');
        if(c.dest_lat!==undefined){
          destSection.style.display='';
          destForecastStrip.innerHTML='';
          destForecastController = new AbortController();
          renderForecastInto(c.dest_lat,c.dest_lon,destForecastStrip,destForecastController.signal);
        }else{
          destSection.style.display='none';
        }

        document.getElementById('detail-map-btn').href=buildMapUrl(c);
        const shareText=`【${c.name}】を走ってきました！\n距離: ${c.distance_km}km / 片道${fmtHours(c.duration_hours)}\n目的地: ${c.destination}\n#ツーリング #バイク`;
        // X share: short URL を非同期で差し込む（即時は fallback URL）
        const xBtn=document.getElementById('share-x-btn');
        xBtn.href='https://twitter.com/intent/tweet?text='+encodeURIComponent(shareText);
        getShareUrl(idx).then(url=>{
          xBtn.href='https://twitter.com/intent/tweet?text='+encodeURIComponent(shareText+'\n'+url);
        }).catch(()=>{});
        const sd={name:c.name,distance_km:c.distance_km,duration_hours:c.duration_hours,destination:c.destination,highlights:c.highlights,road_types:c.road_types,outbound_spots:outboundSpots,return_spots:returnSpots,caution:c.caution,best_season:c.best_season,photo_spot:c.photo_spot,return_note:c.return_note,return_hours:c.return_hours,tags:c.tags,difficulty:c.difficulty,dest_lat:c.dest_lat,dest_lon:c.dest_lon,dest_temp:c.dest_temp,dest_weather_code:c.dest_weather_code,_distIdx:idx};
        try{
          const b64=btoa(encodeURIComponent(JSON.stringify(sd)));
          const inDetail=document.getElementById('screen-detail').classList.contains('active');
          if(inDetail) history.replaceState({course:b64},'','?course='+b64);
          else         history.pushState({course:b64},'','?course='+b64);
        }catch(_){}
        showScreen('screen-detail');
        // 詳細画面を開くたびにバイクアニメーションを先頭から再スタート
        const bikeEl = document.querySelector('.wc-bike');
        if (bikeEl) { bikeEl.style.animation='none'; void bikeEl.offsetHeight; bikeEl.style.animation=''; }
      }

      async function getShareUrl(idx){
        if(shortUrlCache[idx]) return shortUrlCache[idx];
        const c=courses[idx];
        const res=await fetch(`${API_BASE}/api/share`,{
          method:'POST',
          headers:{...apiHeaders(),'Content-Type':'application/json'},
          body:JSON.stringify({course:c})
        });
        if(!res.ok) throw new Error('share failed');
        const data=await res.json();
        shortUrlCache[idx]=data.url;
        return data.url;
      }

      async function copyUrl(){
        const btn=document.getElementById('share-url-btn');
        btn.textContent='⏳ 生成中...';
        let url=location.href;
        try{
          url=await getShareUrl(detailCourseIdx);
        }catch(_){}
        try{await navigator.clipboard.writeText(url);}
        catch(_){const ta=Object.assign(document.createElement('textarea'),{value:url,style:'position:fixed;opacity:0'});document.body.appendChild(ta);ta.focus();ta.select();document.execCommand('copy');document.body.removeChild(ta);}
        btn.textContent='✅ コピーしました';
        setTimeout(()=>{btn.textContent='🔗 URLをコピー';},1500);
      }

      function showError(msg, type='error') {
        const isLimit = type === 'limit';
        document.getElementById('error-icon').textContent  = isLimit ? '📅' : '⚠️';
        document.getElementById('error-title').textContent = isLimit ? '本日の上限に達しました' : 'エラーが発生しました';
        document.getElementById('error-msg').textContent   = msg;
        document.getElementById('btn-error-retry').textContent = isLimit ? 'トップに戻る' : 'もう一度試す';
        showScreen('screen-error');
      }

      async function findCourses(){
        // 利用上限チェック
        if (remainingUses !== null && remainingUses <= 0) {
          showError('本日の利用上限（3回）に達しました。\n明日またお試しください。', 'limit');
          return;
        }

        // 手動入力モードで空欄なら事前チェック
        if (locationMode === 'manual') {
          const inputVal = (document.getElementById('origin-input')?.value ?? '').trim();
          if (!inputVal) { showError('出発地を入力してください。\n例: 横浜、新宿、名古屋駅など'); return; }
        }

        const wsub=document.getElementById('weather-subtitle');
        const fwrap=document.getElementById('forecast-wrap');
        if(wsub) wsub.style.display='none';
        if(fwrap) fwrap.style.display='none';

        const stepGpsText = document.getElementById('step-gps-text');
        if (stepGpsText) stepGpsText.textContent = locationMode === 'manual' ? '出発地を検索中' : '現在地を取得中';

        showScreen('screen-loading');
        ['step-gps','step-weather','step-ai'].forEach(id=>setStep(id,'idle'));

        setStep('step-gps','active');
        let lat,lon;
        if (locationMode === 'manual') {
          const inputVal = document.getElementById('origin-input').value.trim();
          try {
            const result = await geocodeOrigin(inputVal);
            lat = result.lat; lon = result.lon;
            userLat = lat; userLon = lon;
            originDisplayName = inputVal;
            setStep('step-gps','done');
          } catch(_) {
            showError(`「${inputVal}」の場所が見つかりませんでした。\n別の表現で試してください。\n例: 都市名・駅名・住所など`);
            return;
          }
        } else {
          try{
            const pos=await new Promise((res,rej)=>navigator.geolocation.getCurrentPosition(res,rej,{enableHighAccuracy:false,timeout:30000}));
            lat=pos.coords.latitude;lon=pos.coords.longitude;userLat=lat;userLon=lon;
            originDisplayName='現在地';
            setStep('step-gps','done');
          }catch(e){
            showError(e.code===1?'GPS（位置情報）のアクセスが拒否されました。\n設定から許可するか、出発地を手動で入力してください。':
                      e.code===3?'GPS取得がタイムアウトしました。\nもう一度試してください。':
                      '現在地の取得に失敗しました。');return;
          }
        }

        setStep('step-weather','active');
        let temperature=20,weatherCondition='晴れ';
        try{
          const res=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weathercode&timezone=auto`);
          const d=await res.json();
          temperature=Math.round(d.current.temperature_2m);
          const wCode=d.current.weathercode??0;
          weatherCondition=WEATHER[wCode]??'晴れ';
          weatherMeta={...getWeatherMeta(wCode),temp:temperature};
        }catch(_){}
        setStep('step-weather','done');

        setStep('step-ai','active');
        try{
          const prefs = Array.from(selectedPrefs);
          const reqBody = {latitude:lat,longitude:lon,temperature,weather_condition:weatherCondition};
          if (prefs.length > 0) reqBody.preferences = prefs;
          const res=await fetch(`${API_BASE}/api/suggest`,{method:'POST',headers:apiHeaders(),body:JSON.stringify(reqBody)});
          if(!res.ok){const err=new Error();err.status=res.status;throw err;}
          const data=await res.json();
          setStep('step-ai','done');

          renderSlider(data);
          showScreen('screen-results');
          initSlider();

          renderWeatherInfo();
          renderForecast(lat,lon);
          fetchUsage();
        }catch(e){
          if(e && e.status===429){
            fetchUsage();
            showError('本日の利用上限（3回）に達しました。\n明日またお試しください。', 'limit');
          } else {
            showError('コースの生成に失敗しました。\n通信状況を確認して再試行してください。');
          }
        }
      }

      function backFromDetail() {
        history.pushState({},'',location.pathname);
        const vp=document.getElementById('card-viewport');
        if(vp && vp.children.length > 0){ showScreen('screen-results'); }
        else { showScreen('screen-idle'); }
      }

      document.getElementById('btn-start').addEventListener('click',findCourses);
      document.getElementById('btn-retry').addEventListener('click',findCourses);
      document.getElementById('origin-input').addEventListener('keydown', e => {
        if (e.key === 'Enter') { e.preventDefault(); findCourses(); }
      });
      document.getElementById('btn-back').addEventListener('click', backFromDetail);

      // ブラウザ・iOS ネイティブ戻るジェスチャー対応
      window.addEventListener('popstate', () => {
        if (document.getElementById('screen-detail').classList.contains('active')) {
          backFromDetail();
        }
      });
      document.getElementById('btn-error-retry').addEventListener('click',()=>showScreen('screen-idle'));
      document.getElementById('share-url-btn').addEventListener('click',copyUrl);

      // 出発地モード切替
      document.getElementById('btn-loc-gps').addEventListener('click', () => {
        locationMode = 'gps';
        document.getElementById('btn-loc-gps').classList.add('active');
        document.getElementById('btn-loc-manual').classList.remove('active');
        document.getElementById('origin-input-wrap').style.display = 'none';
      });
      document.getElementById('btn-loc-manual').addEventListener('click', () => {
        locationMode = 'manual';
        document.getElementById('btn-loc-manual').classList.add('active');
        document.getElementById('btn-loc-gps').classList.remove('active');
        document.getElementById('origin-input-wrap').style.display = 'block';
        document.getElementById('origin-input').focus();
      });

      // タグ選択（排他制御あり）
      document.getElementById('pref-tags').addEventListener('click', e => {
        const btn = e.target.closest('.pref-tag');
        if (!btn) return;
        const tag = btn.dataset.tag;
        const exclusive = btn.dataset.exclusive;
        if (selectedPrefs.has(tag)) {
          selectedPrefs.delete(tag);
          btn.classList.remove('selected');
        } else {
          selectedPrefs.add(tag);
          btn.classList.add('selected');
          if (exclusive) {
            selectedPrefs.delete(exclusive);
            document.querySelector(`.pref-tag[data-tag="${exclusive}"]`)?.classList.remove('selected');
          }
        }
      });

      // トースト表示
      function showToast(msg) {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
      }

      // ?admin=トークン で管理者モードを localStorage に保存
      (function(){
        const params = new URLSearchParams(location.search);
        const token  = params.get('admin');
        if (token) {
          localStorage.setItem('adminToken', token);
          params.delete('admin');
          const newUrl = location.pathname + (params.toString() ? '?' + params.toString() : '');
          history.replaceState({}, '', newUrl);
          showToast('🔑 管理者モード有効');
          fetchUsage();
        }
        // ?admin=off で解除
        if (params.get('admin') === 'off') {
          localStorage.removeItem('adminToken');
          showToast('管理者モード解除');
          fetchUsage();
        }
      })();

      (function(){
        const param=new URLSearchParams(location.search).get('course');
        if(!param)return;
        try{const c=JSON.parse(decodeURIComponent(atob(param)));courses=[c];openDetail(0);}catch(_){}
      })();

      // 残り利用回数バッジ
      function renderUsageBadge(used, limit, isAdmin) {
        const badge = document.getElementById('usage-badge');
        const dots  = document.getElementById('usage-dots');
        const text  = document.getElementById('usage-text');
        if(!badge) return;
        if(isAdmin){ badge.style.visibility='hidden'; return; }
        const remaining = Math.max(0, limit - used);
        dots.innerHTML = Array.from({length: limit}, (_, i) =>
          `<span class="dot${i < used ? ' used' : ''}"></span>`
        ).join('');
        text.textContent = `今日あと ${remaining} 回`;
        remainingUses = remaining;
        badge.classList.toggle('limit-reached', remaining === 0);
        badge.style.visibility = 'visible';
      }

      async function fetchUsage() {
        try {
          const res = await fetch(`${API_BASE}/api/status`, {headers: apiHeaders()});
          if(!res.ok) return;
          const d = await res.json();
          renderUsageBadge(d.used, d.limit, d.admin);
        } catch(_) {}
      }
      fetchUsage();

      if('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(()=>{});
    </script>
  </body>
</html>
