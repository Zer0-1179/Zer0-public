---
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="現在地からバイクのツーリングコースをAIが提案" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Zer0 Touring" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta property="og:title" content="Zer0 Touring - AIがツーリングコースを提案" />
    <meta property="og:description" content="現在地と天気をもとにAIが日帰りバイクコースを3つ提案します" />
    <meta property="og:image" content="https://touring.zer0-infra.com/icons/icon-512.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://touring.zer0-infra.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>Zer0 Touring</title>
    <style is:global>
      :root {
        --bg:     #0f172a;
        --card:   #1e2d40;
        --card2:  #243044;
        --text:   #f1f5f9;
        --muted:  #94a3b8;
        --accent: #f97316;
        --border: #2d3f55;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
        min-height: 100svh; -webkit-font-smoothing: antialiased;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-14px); }
      }
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: none; }
      }
      @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
      @keyframes spin { to { transform: rotate(360deg); } }

      .screen { display: none; }
      .screen.active { display: flex; flex-direction: column; min-height: 100svh; animation: fadeIn .3s ease; }

      /* ── Landing ── */
      #screen-idle {
        align-items: center; justify-content: center;
        padding: 2rem; text-align: center; gap: 1.5rem;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(249,115,22,.08) 0%, transparent 70%);
      }
      .hero-icon {
        font-size: 5rem; line-height: 1;
        animation: float 3s ease-in-out infinite;
        filter: drop-shadow(0 8px 24px rgba(249,115,22,.3));
      }
      .hero-title { font-size: 2rem; font-weight: 700; letter-spacing: -.02em; }
      .hero-sub   { color: var(--muted); font-size: .95rem; line-height: 1.7; }

      /* ── Loading ── */
      #screen-loading { align-items: center; justify-content: center; padding: 2rem; gap: 2.5rem; }
      .loading-title  { font-size: 1.25rem; font-weight: 600; }
      .steps { display: flex; flex-direction: column; gap: 1.25rem; width: 100%; max-width: 300px; }
      .step  { display: flex; align-items: center; gap: .875rem; color: var(--muted); font-size: .95rem; }
      .step.active { color: var(--accent); }
      .step.done   { color: #22c55e; }
      .step-icon   { width: 2rem; text-align: center; font-size: 1.25rem; flex-shrink: 0; }
      .spinner {
        display: inline-block; width: 1.25rem; height: 1.25rem;
        border: 2px solid var(--border); border-top-color: var(--accent);
        border-radius: 50%; animation: spin .7s linear infinite;
      }

      /* ── ボタン ── */
      .btn-primary {
        background: var(--accent); color: #fff; border: none;
        border-radius: 9999px; padding: 1rem 0; font-size: 1.125rem;
        font-weight: 600; cursor: pointer; width: 100%; max-width: 320px;
        transition: opacity .15s, transform .1s;
        box-shadow: 0 4px 20px rgba(249,115,22,.35);
      }
      .btn-primary:active { opacity: .75; transform: scale(.97); }
      .btn-outline {
        background: transparent; color: var(--accent);
        border: 1.5px solid var(--accent); border-radius: 9999px;
        padding: .5rem 1.25rem; font-size: .875rem; font-weight: 500;
        cursor: pointer; white-space: nowrap; transition: background .15s;
      }
      .btn-outline:hover { background: rgba(249,115,22,.1); }
      .btn-ghost {
        background: transparent; color: var(--muted);
        border: 1.5px solid var(--border); border-radius: 9999px;
        padding: .5rem 1.25rem; font-size: .875rem; font-weight: 500;
        cursor: pointer; white-space: nowrap; transition: border-color .15s, color .15s;
      }
      .btn-ghost:hover { border-color: var(--muted); color: var(--text); }

      /* ── topbar ── */
      .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: .875rem 1.5rem; border-bottom: 1px solid var(--border);
        position: sticky; top: 0; background: var(--bg); z-index: 10; width: 100%;
      }
      .topbar-left  { display: flex; flex-direction: column; gap: .15rem; flex: 1; }
      .topbar-title { font-size: 1.1rem; font-weight: 700; }
      .weather-subtitle {
        display: none;
        font-size: .8rem; font-weight: 600; color: #93c5fd;
        background: rgba(147,197,253,.1); border: 1px solid rgba(147,197,253,.22);
        border-radius: 9999px; padding: .16rem .65rem; align-self: flex-start;
      }
      .topbar-btns  { display: flex; gap: .5rem; }

      /* ════════════════════════════════════════
         スワイプカードスライダー
         overflow:hidden + translateX で確実に動作
      ════════════════════════════════════════ */
      #screen-results { align-items: center; }

      .slider-outer {
        width: 100%; max-width: 560px;
        padding: 1.25rem 1.5rem 0;
        animation: slideUp .5s ease both;
      }
      @media (max-width: 679px) {
        .slider-outer { padding: 1rem .875rem 0; }
      }

      .slider-dots {
        display: flex; justify-content: center; gap: .6rem;
        margin-bottom: .875rem;
      }
      .dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--border); cursor: pointer; border: none; padding: 0;
        transition: background .25s, transform .25s;
      }
      .dot.active { background: var(--accent); transform: scale(1.4); }

      /* scroll-snap スライダー本体 */
      .card-viewport {
        display: flex;
        overflow-x: scroll;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        border-radius: .875rem;
        border: 1px solid var(--border);
        width: 100%;
      }
      .card-viewport::-webkit-scrollbar { display: none; }

      /* ─── コースカード ─── */
      .course-card {
        flex: 0 0 100%;
        scroll-snap-align: start;
        background: var(--card);
        display: flex; flex-direction: column;
        -webkit-tap-highlight-color: transparent;
        min-width: 0;
      }

      /* グラデーションヘッダー */
      .card-header {
        width: 100%; height: 130px; position: relative; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
      }
      .card-header-icon {
        font-size: 2.75rem;
        filter: drop-shadow(0 4px 16px rgba(0,0,0,.55));
        animation: float 3.5s ease-in-out infinite;
      }
      .card-header-badges {
        position: absolute; bottom: .75rem; left: .875rem;
        display: flex; gap: .4rem;
      }

      /* 情報エリア */
      .card-body {
        padding: 1.1rem 1.25rem .875rem;
        display: flex; flex-direction: column; gap: .55rem; flex: 1;
      }
      .card-name { font-size: 1.2rem; font-weight: 700; line-height: 1.3; }
      .course-tags { display: flex; gap: .3rem; flex-wrap: wrap; }
      .course-tag {
        font-size: .75rem; font-weight: 600;
        background: rgba(255,255,255,.08); color: rgba(255,255,255,.85);
        border-radius: 9999px; padding: .18rem .58rem;
      }
      .card-info-row {
        display: flex; align-items: center; gap: .45rem;
        font-size: .83rem; color: var(--muted); flex-wrap: wrap;
      }
      .card-info-sep { color: var(--border); user-select: none; }

      /* アクションボタン */
      .card-actions {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: .75rem; padding: .875rem 1.25rem;
        border-top: 1px solid var(--border);
      }
      .card-btn-nav {
        display: flex; align-items: center; justify-content: center; gap: .35rem;
        border: 1px solid rgba(249,115,22,.45);
        background: rgba(249,115,22,.12); color: var(--accent);
        border-radius: .6rem; padding: .75rem;
        font-size: .88rem; font-weight: 600; cursor: pointer; transition: background .15s;
      }
      .card-btn-nav:hover { background: rgba(249,115,22,.22); }
      .card-btn-detail {
        display: flex; align-items: center; justify-content: center;
        border: none; background: var(--card2); color: var(--text);
        border-radius: .6rem; padding: .75rem;
        font-size: .88rem; font-weight: 600; cursor: pointer; transition: background .15s;
      }
      .card-btn-detail:hover { background: var(--border); }

      /* バッジ */
      .dist-tag {
        font-size: .72rem; font-weight: 700; border-radius: .35rem;
        padding: .22rem .65rem; display: inline-flex; align-items: center; gap: .25rem;
      }
      .dist-near { background: rgba(34,197,94,.2);  color: #4ade80; border: 1px solid rgba(34,197,94,.4); }
      .dist-mid  { background: rgba(56,189,248,.2);  color: #7dd3fc; border: 1px solid rgba(56,189,248,.4); }
      .dist-far  { background: rgba(168,85,247,.2);  color: #c4b5fd; border: 1px solid rgba(168,85,247,.4); }

      .dest-weather-badge {
        font-size: .72rem; font-weight: 700; color: #e0f2fe;
        background: rgba(0,0,0,.48); border-radius: .35rem;
        padding: .22rem .6rem; backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,.15);
      }

      /* ════════════════════════════════════════
         天気比較ウィジェット（詳細画面・画像直下）
      ════════════════════════════════════════ */
      .weather-compare {
        width: 100%; max-width: 680px;
        display: none; flex-shrink: 0;
        background: var(--card2); border-bottom: 1px solid var(--border);
      }
      .weather-compare.visible { display: flex; }
      .wc-side {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; padding: 1rem .75rem; gap: .28rem;
      }
      .wc-side.current { border-right: 1px solid var(--border); }
      .wc-label {
        font-size: .62rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .06em;
      }
      .wc-icon { font-size: 1.8rem; line-height: 1; }
      .wc-temp { font-size: 1.3rem; font-weight: 700; }
      .wc-cond { font-size: .72rem; color: var(--muted); text-align: center; }
      .wc-arrow {
        position: relative;
        display: flex; align-items: center; justify-content: center;
        width: 80px; flex-shrink: 0; overflow: hidden;
      }
      .wc-bike {
        position: relative; font-size: 1.15rem;
        animation: bike-ride 4s ease-in-out infinite;
      }
      @keyframes bike-ride {
        0%   { transform: translateX(-36px) scaleX(-1); opacity: 0; }
        8%   { transform: translateX(-36px) scaleX(-1); opacity: 1; }
        80%  { transform: translateX(36px)  scaleX(-1); opacity: 1; }
        93%  { transform: translateX(36px)  scaleX(-1); opacity: 0; }
        100% { transform: translateX(-36px) scaleX(-1); opacity: 0; }
      }

      @media (max-width: 679px) {
        .topbar { padding: .6rem 1rem; }
        .card-name { font-size: 1.1rem; }
      }

      /* ════════════════════════════════════════
         週間天気予報
      ════════════════════════════════════════ */
      #forecast-wrap {
        width: 100%; max-width: 560px;
        padding: 1.25rem 1.5rem 2rem; display: none;
      }
      @media (max-width: 679px) { #forecast-wrap { padding: 1rem .875rem 1.5rem; } }
      .forecast-label {
        font-size: .68rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .06em;
        border-bottom: 1px solid var(--border);
        padding-bottom: .4rem; margin-bottom: .65rem;
      }
      .forecast-strip {
        display: flex; gap: .5rem;
        overflow-x: auto; padding-bottom: .4rem;
        scrollbar-width: thin; scrollbar-color: var(--border) transparent;
      }
      .forecast-strip::-webkit-scrollbar { height: 4px; }
      .forecast-strip::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
      .forecast-day {
        display: flex; flex-direction: column; align-items: center;
        gap: .22rem; flex-shrink: 0; min-width: 60px;
        background: var(--card2); border: 1px solid var(--border);
        border-radius: .65rem; padding: .55rem .6rem; font-size: .7rem;
      }
      .forecast-day.today { border-color: rgba(56,189,248,.5); background: rgba(56,189,248,.06); }
      .forecast-day.best  { border-color: rgba(249,115,22,.6); background: rgba(249,115,22,.1); }
      .fd-dow  { font-size: .65rem; font-weight: 700; color: var(--muted); }
      .fd-icon { font-size: 1.3rem; line-height: 1; }
      .fd-temp { font-weight: 700; }
      .fd-best { font-size: .6rem; font-weight: 700; color: var(--accent); white-space: nowrap; }
      .fd-score { display: flex; gap: 2px; }
      .fd-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--border); }
      .fd-dot.on { background: var(--accent); }

      /* ════════════════════════════════════════
         コース詳細
      ════════════════════════════════════════ */
      #screen-detail { overflow-y: auto; align-items: center; }
      #screen-detail > .topbar,
      #screen-detail > .detail-img-wrap,
      #screen-detail > .weather-compare,
      #screen-detail > .detail-content { width: 100%; max-width: 680px; }

      .detail-img-wrap {
        width: 100%; height: 160px; overflow: hidden; flex-shrink: 0;
        background: var(--card2); position: relative;
      }
      .detail-img-ph {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: .4rem;
      }
      .detail-img {
        position: absolute; inset: 0; width: 100%; height: 100%;
        object-fit: cover; opacity: 0; transition: opacity .4s;
      }
      .detail-img.loaded { opacity: 1; }
      .detail-content {
        display: flex; flex-direction: column; gap: 1.5rem;
        padding: 1.5rem 1.25rem 2.5rem; flex: 1;
      }
      .detail-header { display: flex; flex-direction: column; gap: .65rem; }
      .detail-tag-row { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
      .detail-name { font-size: 1.5rem; font-weight: 700; line-height: 1.3; }
      .detail-meta { display: flex; gap: .4rem; flex-wrap: wrap; }
      .meta-pill-lg {
        font-size: .82rem; color: var(--muted);
        background: var(--card2); border-radius: 9999px; padding: .25rem .75rem;
      }
      .section { display: flex; flex-direction: column; gap: .6rem; }
      .section-title {
        font-size: .68rem; font-weight: 700; color: var(--muted);
        text-transform: uppercase; letter-spacing: .06em;
        border-bottom: 1px solid var(--border); padding-bottom: .4rem;
      }
      .highlights { list-style: none; display: flex; flex-direction: column; gap: .45rem; }
      .highlights li { font-size: .9rem; padding-left: 1.4rem; position: relative; }
      .highlights li::before { content: "📍"; position: absolute; left: 0; font-size: .8rem; }
      .road-tags-lg { display: flex; gap: .4rem; flex-wrap: wrap; }
      .road-tag-lg {
        display: inline-flex; align-items: center; gap: .3rem;
        background: var(--card2); border: 1px solid var(--border);
        border-radius: .4rem; padding: .3rem .7rem; font-size: .85rem;
      }
      .rest-spots { display: flex; flex-direction: column; gap: .4rem; }
      .spot-item {
        display: flex; align-items: center; gap: .6rem;
        background: var(--card2); border-radius: .5rem; padding: .6rem .75rem;
      }
      .spot-icon { font-size: 1.1rem; flex-shrink: 0; }
      .spot-name { font-size: .9rem; font-weight: 500; flex: 1; }
      .spot-type {
        font-size: .7rem; color: var(--muted);
        background: var(--border); border-radius: 9999px; padding: .1rem .5rem; white-space: nowrap;
      }
      .info-chips { display: flex; flex-direction: column; gap: .5rem; }
      .info-chip {
        display: flex; align-items: flex-start; gap: .5rem;
        font-size: .85rem; padding: .6rem .75rem; border-radius: .5rem;
      }
      .info-return  { background: rgba(56,189,248,.1);  color: #7dd3fc; border: 1px solid rgba(56,189,248,.3); }
      .info-caution { background: rgba(239,68,68,.1);   color: #fca5a5; border: 1px solid rgba(239,68,68,.3); }
      .info-season  { background: rgba(34,197,94,.1);   color: #86efac; border: 1px solid rgba(34,197,94,.3); }
      .btn-map {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        text-decoration: none; background: transparent;
        color: var(--accent); border: 1.5px solid var(--accent);
        border-radius: .75rem; padding: .875rem; font-size: .95rem; font-weight: 600;
        transition: background .15s;
      }
      .btn-map:hover { background: rgba(249,115,22,.1); }
      .btn-x-share {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        text-decoration: none; background: #000; color: #fff;
        border-radius: .75rem; padding: .875rem; font-size: .95rem; font-weight: 600;
        transition: opacity .15s;
      }
      .btn-x-share:hover { opacity: .85; }
      .btn-url-copy {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        width: 100%; border: none; cursor: pointer;
        background: #1a2744; color: #fff;
        border-radius: .75rem; padding: .875rem; font-size: .95rem; font-weight: 600;
        transition: opacity .15s;
      }
      .btn-url-copy:hover { opacity: .85; }

      @media (max-width: 679px) {
        .detail-content { padding: 1.25rem 1rem 2rem; gap: 1.25rem; }
        .detail-name { font-size: 1.25rem; }
      }

      /* ── Error ── */
      #screen-error {
        align-items: center; justify-content: center;
        padding: 2rem; text-align: center; gap: 1.25rem;
      }
      .error-icon  { font-size: 4rem; }
      .error-title { font-size: 1.25rem; font-weight: 600; }
      .error-msg   { color: var(--muted); font-size: .9rem; line-height: 1.7; max-width: 300px; white-space: pre-line; }
    </style>
  </head>
  <body>

    <!-- ── Landing ── -->
    <div id="screen-idle" class="screen active">
      <div class="hero-icon">🏍️</div>
      <h1 class="hero-title">Zer0 Touring</h1>
      <p class="hero-sub">現在地と天気をもとに<br/>AIが日帰りコースを3つ提案します</p>
      <button class="btn-primary" id="btn-start">コースを探す</button>
    </div>

    <!-- ── Loading ── -->
    <div id="screen-loading" class="screen">
      <p class="loading-title">コースを検索中...</p>
      <div class="steps">
        <div class="step" id="step-gps"><span class="step-icon" id="icon-gps">📍</span><span>現在地を取得中</span></div>
        <div class="step" id="step-weather"><span class="step-icon" id="icon-weather">🌤</span><span>天気を確認中</span></div>
        <div class="step" id="step-ai"><span class="step-icon" id="icon-ai">🤖</span><span>AIがコースを生成中</span></div>
      </div>
    </div>

    <!-- ── コース一覧（スワイプスライダー）── -->
    <div id="screen-results" class="screen">
      <div class="topbar">
        <div class="topbar-left">
          <span class="topbar-title">おすすめコース</span>
          <span id="weather-subtitle" class="weather-subtitle"></span>
        </div>
        <div class="topbar-btns">
          <button class="btn-outline" id="btn-retry">再検索</button>
        </div>
      </div>

      <div class="slider-outer">
        <div class="slider-dots" id="slider-dots"></div>
        <div class="card-viewport" id="card-viewport">
        </div>
      </div>

      <div id="forecast-wrap">
        <p class="forecast-label">現在地・今週の天気</p>
        <div class="forecast-strip" id="forecast-strip"></div>
      </div>
    </div>

    <!-- ── コース詳細 ── -->
    <div id="screen-detail" class="screen">
      <div class="topbar">
        <button class="btn-ghost" id="btn-back">← 一覧に戻る</button>
      </div>
      <div class="detail-img-wrap">
        <div class="detail-img-ph" id="detail-img-ph"></div>
        <img class="detail-img" id="detail-img" alt="コース写真" loading="eager" />
      </div>
      <div id="detail-weather-compare" class="weather-compare">
        <div class="wc-side current" id="wc-current"></div>
        <div class="wc-arrow">
          <span class="wc-bike">🏍️</span>
        </div>
        <div class="wc-side dest" id="wc-dest"></div>
      </div>
      <div class="detail-content">
        <div class="detail-header">
          <div class="detail-tag-row" id="detail-tags"></div>
          <p  class="detail-name"    id="detail-name"></p>
          <div class="detail-meta"   id="detail-meta"></div>
        </div>
        <div class="section">
          <p class="section-title">見どころ</p>
          <ul class="highlights" id="detail-highlights"></ul>
        </div>
        <div class="section">
          <p class="section-title">道路タイプ</p>
          <div class="road-tags-lg" id="detail-roads"></div>
        </div>
        <div class="section">
          <p class="section-title">立ち寄りスポット</p>
          <div class="rest-spots" id="detail-spots"></div>
        </div>
        <div class="section" id="detail-dest-weather-section" style="display:none">
          <p class="section-title">目的地の今週の天気</p>
          <div class="forecast-strip" id="detail-dest-forecast-strip"></div>
        </div>
        <div class="section">
          <p class="section-title">走行情報</p>
          <div class="info-chips" id="detail-info"></div>
        </div>
        <a id="detail-map-btn" href="#" target="_blank" rel="noopener noreferrer" class="btn-map">🗺 Googleマップでナビ開始</a>
        <a id="share-x-btn"  href="#" target="_blank" rel="noopener noreferrer" class="btn-x-share">𝕏 でシェア</a>
        <button id="share-url-btn" class="btn-url-copy">🔗 URLをコピー</button>
      </div>
    </div>

    <!-- ── Error ── -->
    <div id="screen-error" class="screen" style="display:none">
      <span class="error-icon">⚠️</span>
      <h2 class="error-title">エラーが発生しました</h2>
      <p class="error-msg" id="error-msg"></p>
      <button class="btn-primary" id="btn-error-retry">もう一度試す</button>
    </div>

    <script>
      const API_BASE = import.meta.env.PUBLIC_API_URL ?? '';

      const WEATHER = {
        0:'晴れ',1:'晴れのち曇り',2:'曇り',3:'曇り',45:'霧',48:'霧',
        51:'小雨',53:'雨',55:'大雨',61:'小雨',63:'雨',65:'大雨',
        71:'小雪',73:'雪',75:'大雪',77:'雪',80:'にわか雨',81:'にわか雨',
        82:'にわか大雨',85:'にわか雪',86:'にわか大雪',95:'雷雨',96:'雷雨',99:'激しい雷雨',
      };
      const DIST = [
        { label:'近距離コース', icon:'🌿', cls:'dist-near', grad:'linear-gradient(160deg,#1a3a2a,#2d7a4f)' },
        { label:'中距離コース', icon:'🌊', cls:'dist-mid',  grad:'linear-gradient(160deg,#1a2a4a,#2563eb)' },
        { label:'長距離コース', icon:'🏔', cls:'dist-far',  grad:'linear-gradient(160deg,#3a1a42,#9333ea)' },
      ];
      const ROAD = { '峠道':'🏔','山道':'🏔','高速道路':'🛣','国道':'🚗','一般道':'🚗','県道':'🛤','海岸線':'🌊' };
      const SPOT = { '道の駅':'🏪','温泉':'♨️','展望台':'🔭','カフェ':'☕','食事処':'🍜','観光地':'📸','ガソリンスタンド':'⛽' };

      let courses     = [];
      let userLat     = null, userLon = null;
      let weatherMeta = { icon:'☀️', score:5, label:'絶好の日和！', temp:'--' };
      let currentSlide = 0;

      /* ── 天気ヘルパー ── */
      function getWeatherMeta(code) {
        if (code === 0)                 return { icon:'☀️', score:5, label:'絶好の日和！' };
        if (code <= 2)                  return { icon:'🌤', score:4, label:'ツーリング向き' };
        if (code === 3)                 return { icon:'☁️', score:3, label:'まずまず' };
        if (code===45 || code===48)     return { icon:'🌫', score:2, label:'視界に注意' };
        if (code>=51 && code<=67)       return { icon:'🌧', score:1, label:'雨天注意' };
        if (code>=71 && code<=77)       return { icon:'🌨', score:1, label:'降雪注意' };
        if (code>=80 && code<=82)       return { icon:'🌦', score:2, label:'にわか雨注意' };
        if (code>=95)                   return { icon:'⛈', score:0, label:'走行危険' };
        return { icon:'🌤', score:3, label:'まずまず' };
      }
      function renderWeatherInfo() {
        const el = document.getElementById('weather-subtitle');
        if (!el) return;
        el.textContent = `📍現在地  ${weatherMeta.icon} ${weatherMeta.temp}℃ · ${weatherMeta.label}`;
        el.style.display = 'inline-flex';
      }
      async function renderForecastInto(lat, lon, stripEl) {
        try {
          const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&daily=weathercode,temperature_2m_max&timezone=auto&forecast_days=7`);
          const d = await res.json();
          const { time, weathercode, temperature_2m_max } = d.daily;
          let bestIdx=1, bestScore=-1;
          weathercode.forEach((c,i)=>{if(i===0)return;const s=getWeatherMeta(c).score;if(s>bestScore){bestScore=s;bestIdx=i;}});
          const DOW=['日','月','火','水','木','金','土'];
          stripEl.innerHTML=time.map((t,i)=>{
            const date=new Date(t+'T00:00:00');
            const meta=getWeatherMeta(weathercode[i]);
            const temp=Math.round(temperature_2m_max[i]);
            const dots=Array.from({length:5},(_,di)=>`<span class="fd-dot${di<meta.score?' on':''}"></span>`).join('');
            return `<div class="forecast-day${i===0?' today':''}${i===bestIdx?' best':''}">
              <span class="fd-dow">${i===0?'今日':DOW[date.getDay()]}</span>
              <span class="fd-icon">${meta.icon}</span>
              <span class="fd-temp">${temp}℃</span>
              <div class="fd-score">${dots}</div>
              ${i===bestIdx?'<span class="fd-best">★ 狙い目</span>':''}
            </div>`;
          }).join('');
        } catch(_){}
      }
      async function renderForecast(lat, lon) {
        const strip=document.getElementById('forecast-strip');
        const wrap=document.getElementById('forecast-wrap');
        if(!strip||!wrap)return;
        await renderForecastInto(lat, lon, strip);
        if(strip.innerHTML) wrap.style.display='block';
      }

      /* ─────────────────────────────────────
         スライダー
         showScreen の後に initSlider() を呼ぶことで
         clientWidth が正しく取れる
      ───────────────────────────────────── */
      function updateDots() {
        document.querySelectorAll('.dot').forEach((dot,i)=>{
          dot.classList.toggle('active', i===currentSlide);
        });
      }

      function goTo(idx) {
        const vp = document.getElementById('card-viewport');
        currentSlide = Math.max(0, Math.min(idx, courses.length-1));
        vp.scrollTo({ left: currentSlide * vp.clientWidth, behavior: 'smooth' });
        updateDots();
      }

      function initSlider() {
        const vp = document.getElementById('card-viewport');
        vp.scrollLeft = 0;
        currentSlide  = 0;
        vp.addEventListener('scroll', () => {
          if (!vp.clientWidth) return;
          const idx = Math.round(vp.scrollLeft / vp.clientWidth);
          if (idx !== currentSlide) { currentSlide = idx; updateDots(); }
        }, { passive: true });
      }

      function renderSlider(data) {
        courses = [...data.courses].sort((a,b)=>(a.distance_km??0)-(b.distance_km??0));
        currentSlide = 0;

        const vp     = document.getElementById('card-viewport');
        const dotsEl = document.getElementById('slider-dots');

        vp.innerHTML = courses.map((c,i) => {
          const d = DIST[i];
          const tagsHtml = (c.tags??[]).slice(0,3).map(t=>`<span class="course-tag">${t}</span>`).join('');
          const destWeatherBadge = c.dest_weather_code !== undefined
            ? (() => { const m = getWeatherMeta(c.dest_weather_code); return `<span class="dest-weather-badge">📌 ${m.icon} ${c.dest_temp}℃</span>`; })()
            : '';
          return `
            <article class="course-card" data-idx="${i}">
              <div class="card-header" style="background:${d.grad}">
                <span class="card-header-icon">🏍️</span>
                <div class="card-header-badges">
                  <span class="dist-tag ${d.cls}">${d.icon} ${d.label}</span>
                  ${destWeatherBadge}
                </div>
              </div>
              <div class="card-body">
                <h3 class="card-name">${c.name}</h3>
                ${tagsHtml?`<div class="course-tags">${tagsHtml}</div>`:''}
                <div class="card-info-row">
                  <span>🛣 ${c.distance_km}km</span>
                  <span class="card-info-sep">·</span>
                  <span>⏱ 片道${c.duration_hours}h走行</span>
                  <span class="card-info-sep">·</span>
                  <span>🏁 ${c.destination}</span>
                </div>
              </div>
              <div class="card-actions">
                <button class="card-btn-nav">🗺 ナビ開始</button>
                <button class="card-btn-detail">詳細を見る →</button>
              </div>
            </article>`;
        }).join('');

        // ボタンイベント
        vp.querySelectorAll('.course-card').forEach(card => {
          card.querySelector('.card-btn-detail').addEventListener('click',()=>openDetail(+card.dataset.idx));
          card.querySelector('.card-btn-nav').addEventListener('click',()=>{
            window.location.href = buildMapUrl(courses[+card.dataset.idx]);
          });
        });

        // ドット
        dotsEl.innerHTML = courses.map((_,i)=>
          `<button class="dot${i===0?' active':''}" data-i="${i}" aria-label="コース${i+1}"></button>`
        ).join('');
        dotsEl.querySelectorAll('.dot').forEach(dot=>{
          dot.addEventListener('click',()=>goTo(+dot.dataset.i));
        });
        // ← initSlider() は showScreen() の後に呼ぶ
      }

      /* ── スクリーン ── */
      function showScreen(id) {
        document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        window.scrollTo(0,0);
      }

      const SICONS={'step-gps':'📍','step-weather':'🌤','step-ai':'🤖'};
      const SIIDS ={'step-gps':'icon-gps','step-weather':'icon-weather','step-ai':'icon-ai'};
      function setStep(id,state){
        const el=document.getElementById(id);
        const ic=document.getElementById(SIIDS[id]);
        el.className='step'+(state==='active'?' active':state==='done'?' done':'');
        if(state==='active') ic.innerHTML='<span class="spinner"></span>';
        else if(state==='done') ic.textContent='✅';
        else ic.textContent=SICONS[id];
      }

      async function loadPhoto(spot,imgEl){
        if(!imgEl||!spot)return;
        try{
          const res=await fetch('https://ja.wikipedia.org/api/rest_v1/page/summary/'+encodeURIComponent(spot));
          const data=await res.json();
          const src=data.thumbnail?.source;
          if(!src)return;
          imgEl.onload=()=>imgEl.classList.add('loaded');
          imgEl.onerror=()=>{imgEl.src='';imgEl.classList.remove('loaded');};
          imgEl.src=src.replace(/\/\d+px-/,'/1280px-');
        }catch(_){imgEl.src='';}
      }

      function buildMapUrl(c){
        const dest  = encodeURIComponent(c.destination);
        const spots = (c.rest_spots??[]).map(s=>encodeURIComponent(s.name));
        const hasGps = userLat&&userLon;
        const coord  = hasGps?`${userLat.toFixed(6)},${userLon.toFixed(6)}`:'';
        const isIOS  = /iP(hone|ad|od)/.test(navigator.userAgent);
        const op = hasGps?`&origin=${coord}`:'';
        const wp = spots.length?`&waypoints=${spots.join('%7C')}` :'';
        // iOS: comgooglemaps:// でアプリ直起動（waypoints 対応）
        if(isIOS&&hasGps){
          const ioswp=spots.length?`&waypoints=${spots.join('+')}` :'';
          return `comgooglemaps://?saddr=${coord}&daddr=${dest}${ioswp}&directionsmode=driving`;
        }
        // Android / Web: https URL（waypoints 含む。Android はアプリで開く提案が出る）
        return `https://www.google.com/maps/dir/?api=1${op}&destination=${dest}${wp}&travelmode=driving`;
      }

      function openDetail(idx){
        const c=courses[idx];
        const d=DIST[c._distIdx??idx];
        const ph=document.getElementById('detail-img-ph');
        ph.style.background=d.grad;
        ph.innerHTML=`<span style="font-size:2.2rem;filter:drop-shadow(0 4px 12px rgba(0,0,0,.5))">🏍️</span>`;
        const dimg=document.getElementById('detail-img');
        dimg.classList.remove('loaded');dimg.src='';
        loadPhoto(c.photo_spot,dimg);
        document.getElementById('detail-tags').innerHTML=
          `<span class="dist-tag ${d.cls}">${d.icon} ${d.label}</span>`;
        document.getElementById('detail-name').textContent=c.name;
        const rh=c.return_hours??c.duration_hours;
        document.getElementById('detail-meta').innerHTML=
          `<span class="meta-pill-lg">🛣 ${c.distance_km}km</span>`+
          `<span class="meta-pill-lg">⏱ 片道 ${c.duration_hours}h（走行のみ）</span>`+
          `<span class="meta-pill-lg">🔄 往復 ${(c.duration_hours+rh).toFixed(1)}h（走行のみ）</span>`+
          `<span class="meta-pill-lg">🏁 ${c.destination}</span>`;
        document.getElementById('detail-highlights').innerHTML=(c.highlights??[]).map(h=>`<li>${h}</li>`).join('');
        document.getElementById('detail-roads').innerHTML=(c.road_types??[]).map(r=>`<span class="road-tag-lg">${ROAD[r]??'🚗'} ${r}</span>`).join('');
        document.getElementById('detail-spots').innerHTML=(c.rest_spots??[]).map(s=>
          `<div class="spot-item"><span class="spot-icon">${SPOT[s.type]??'📌'}</span><span class="spot-name">${s.name}</span><span class="spot-type">${s.type}</span></div>`
        ).join('');
        document.getElementById('detail-info').innerHTML=[
          c.return_note?`<div class="info-chip info-return"><span>🔄</span><span>帰路: ${c.return_note}</span></div>`:'',
          c.caution    ?`<div class="info-chip info-caution"><span>⚠️</span><span>${c.caution}</span></div>`:'',
          c.best_season?`<div class="info-chip info-season"><span>🌸</span><span>ベストシーズン: ${c.best_season}</span></div>`:'',
        ].filter(Boolean).join('');

        // 現在地 vs 目的地 天気比較ウィジェット
        const compareEl=document.getElementById('detail-weather-compare');
        const wcCurrent=document.getElementById('wc-current');
        const wcDest=document.getElementById('wc-dest');
        const hasCurrentWeather = weatherMeta.temp !== '--';
        const hasDestWeather = c.dest_weather_code !== undefined;
        if(compareEl && (hasCurrentWeather || hasDestWeather)){
          if(wcCurrent){
            if(hasCurrentWeather){
              wcCurrent.innerHTML=`<span class="wc-label">📍現在地</span><span class="wc-icon">${weatherMeta.icon}</span><span class="wc-temp">${weatherMeta.temp}℃</span><span class="wc-cond">${weatherMeta.label}</span>`;
            }else{
              wcCurrent.innerHTML=`<span class="wc-label">📍現在地</span><span class="wc-icon">--</span>`;
            }
          }
          if(wcDest){
            if(hasDestWeather){
              const dm=getWeatherMeta(c.dest_weather_code);
              wcDest.innerHTML=`<span class="wc-label">📌目的地</span><span class="wc-icon">${dm.icon}</span><span class="wc-temp">${c.dest_temp}℃</span><span class="wc-cond">${dm.label}</span>`;
            }else{
              wcDest.innerHTML=`<span class="wc-label">📌目的地</span><span class="wc-icon" style="font-size:1rem;color:var(--muted)">取得中...</span>`;
            }
          }
          compareEl.classList.add('visible');
        }else if(compareEl){
          compareEl.classList.remove('visible');
        }

        // 目的地の7日間予報
        const destSection=document.getElementById('detail-dest-weather-section');
        const destForecastStrip=document.getElementById('detail-dest-forecast-strip');
        if(c.dest_lat!==undefined){
          destSection.style.display='';
          destForecastStrip.innerHTML='';
          renderForecastInto(c.dest_lat,c.dest_lon,destForecastStrip);
        }else{
          destSection.style.display='none';
        }

        document.getElementById('detail-map-btn').href=buildMapUrl(c);
        const shareText=`【${c.name}】を走ってきました！\n距離: ${c.distance_km}km / 約${c.duration_hours}時間\n目的地: ${c.destination}\n#ツーリング #バイク`;
        document.getElementById('share-x-btn').href='https://twitter.com/intent/tweet?text='+encodeURIComponent(shareText);
        const sd={name:c.name,distance_km:c.distance_km,duration_hours:c.duration_hours,destination:c.destination,highlights:c.highlights,road_types:c.road_types,rest_spots:c.rest_spots,caution:c.caution,best_season:c.best_season,photo_spot:c.photo_spot,return_note:c.return_note,return_hours:c.return_hours,tags:c.tags,difficulty:c.difficulty,dest_lat:c.dest_lat,dest_lon:c.dest_lon,dest_temp:c.dest_temp,dest_weather_code:c.dest_weather_code,_distIdx:idx};
        try{const b64=btoa(encodeURIComponent(JSON.stringify(sd)));history.pushState({course:b64},'','?course='+b64);}catch(_){}
        showScreen('screen-detail');
      }

      async function copyUrl(){
        try{await navigator.clipboard.writeText(location.href);}
        catch(_){const ta=Object.assign(document.createElement('textarea'),{value:location.href,style:'position:fixed;opacity:0'});document.body.appendChild(ta);ta.focus();ta.select();document.execCommand('copy');document.body.removeChild(ta);}
        const btn=document.getElementById('share-url-btn');
        btn.textContent='✅ コピーしました';
        setTimeout(()=>{btn.textContent='🔗 URLをコピー';},1500);
      }

      function showError(msg){document.getElementById('error-msg').textContent=msg;showScreen('screen-error');}

      async function findCourses(){
        const wsub=document.getElementById('weather-subtitle');
        const fwrap=document.getElementById('forecast-wrap');
        if(wsub) wsub.style.display='none';
        if(fwrap) fwrap.style.display='none';

        showScreen('screen-loading');
        ['step-gps','step-weather','step-ai'].forEach(id=>setStep(id,'idle'));

        setStep('step-gps','active');
        let lat,lon;
        try{
          const pos=await new Promise((res,rej)=>navigator.geolocation.getCurrentPosition(res,rej,{enableHighAccuracy:false,timeout:30000}));
          lat=pos.coords.latitude;lon=pos.coords.longitude;userLat=lat;userLon=lon;
          setStep('step-gps','done');
        }catch(e){
          showError(e.code===1?'GPS（位置情報）のアクセスが拒否されました。\nブラウザの設定から位置情報を許可してください。':
                    e.code===3?'GPS取得がタイムアウトしました。\nもう一度試してください。':
                    '現在地の取得に失敗しました。');return;
        }

        setStep('step-weather','active');
        let temperature=20,weatherCondition='晴れ';
        try{
          const res=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weathercode&timezone=auto`);
          const d=await res.json();
          temperature=Math.round(d.current.temperature_2m);
          const wCode=d.current.weathercode??0;
          weatherCondition=WEATHER[wCode]??'晴れ';
          weatherMeta={...getWeatherMeta(wCode),temp:temperature};
        }catch(_){}
        setStep('step-weather','done');

        setStep('step-ai','active');
        try{
          const res=await fetch(`${API_BASE}/api/suggest`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({latitude:lat,longitude:lon,temperature,weather_condition:weatherCondition})});
          if(!res.ok) throw new Error();
          const data=await res.json();
          setStep('step-ai','done');

          renderSlider(data);          // HTML・ドット・イベント生成
          showScreen('screen-results'); // display:flex に変わる → clientWidth が確定
          initSlider();                 // ピクセル幅設定・タッチ初期化

          renderWeatherInfo();
          renderForecast(lat,lon);
        }catch(_){showError('コースの生成に失敗しました。\n通信状況を確認して再試行してください。');}
      }

      document.getElementById('btn-start').addEventListener('click',findCourses);
      document.getElementById('btn-retry').addEventListener('click',findCourses);
      document.getElementById('btn-back').addEventListener('click',()=>{history.pushState({},'',location.pathname);showScreen('screen-results');});
      document.getElementById('btn-error-retry').addEventListener('click',()=>showScreen('screen-idle'));
      document.getElementById('share-url-btn').addEventListener('click',copyUrl);

      (function(){
        const param=new URLSearchParams(location.search).get('course');
        if(!param)return;
        try{const c=JSON.parse(decodeURIComponent(atob(param)));courses=[c];openDetail(0);}catch(_){}
      })();

      if('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(()=>{});
    </script>
  </body>
</html>
