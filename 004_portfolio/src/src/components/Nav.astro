---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const otherLang = lang === 'ja' ? 'en' : 'ja';

const currentPath = Astro.url.pathname;
const otherLangPath = currentPath.replace(`/${lang}/`, `/${otherLang}/`).replace(`/${lang}`, `/${otherLang}`);

const navItems = [
  { key: 'nav.home' as const, href: `/${lang}/` },
  { key: 'nav.about' as const, href: `/${lang}/about/` },
  { key: 'nav.projects' as const, href: `/${lang}/projects/` },
  { key: 'nav.articles' as const, href: `/${lang}/articles/` },
  { key: 'nav.contact' as const, href: `/${lang}/contact/` },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-navy-950/95 backdrop-blur border-b border-navy-700/50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- ロゴ -->
    <a href={`/${lang}/`} class="flex items-center gap-2 group">
      <span class="text-accent font-bold text-xl font-mono tracking-tight">Zer0_Infra</span>
    </a>

    <!-- PC ナビゲーション -->
    <div class="hidden md:flex items-center gap-1">
      {navItems.map(({ key, href }) => (
        <a
          href={href}
          class="px-4 py-2 text-sm text-slate-300 hover:text-accent hover:bg-navy-800 rounded transition-colors"
        >
          {t(key)}
        </a>
      ))}
    </div>

    <!-- 右側: 言語切替 + ハンバーガー -->
    <div class="flex items-center gap-3">
      <a
        href={otherLangPath}
        class="px-3 py-1.5 text-xs border border-navy-600 text-slate-400 hover:border-accent hover:text-accent rounded transition-colors"
      >
        {otherLang === 'en' ? 'EN' : 'JA'}
      </a>

      <!-- ハンバーガーボタン（モバイルのみ） -->
      <button
        id="menu-btn"
        type="button"
        class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5 cursor-pointer touch-manipulation select-none"
        aria-label="メニューを開く"
        aria-expanded="false"
        style="-webkit-tap-highlight-color: transparent;"
      >
        <span class="hamburger-line block w-5 h-0.5 bg-slate-300 transition-all duration-200 pointer-events-none"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-slate-300 transition-all duration-200 pointer-events-none"></span>
        <span class="hamburger-line block w-5 h-0.5 bg-slate-300 transition-all duration-200 pointer-events-none"></span>
      </button>
    </div>
  </nav>

  <!-- モバイルメニュー -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-navy-700/50 bg-navy-950/98"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navItems.map(({ key, href }) => (
        <a
          href={href}
          class="px-4 py-3 text-sm text-slate-300 hover:text-accent hover:bg-navy-800 rounded transition-colors"
        >
          {t(key)}
        </a>
      ))}
    </div>
  </div>
</header>

<!-- ヘッダー分の余白 -->
<div class="h-16"></div>

<script>
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const lines = btn.querySelectorAll('.hamburger-line');

  function toggleMenu() {
    const opening = menu.classList.contains('hidden');
    menu.classList.toggle('hidden', !opening);
    btn.setAttribute('aria-expanded', String(opening));
    if (opening) {
      (lines[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)';
      (lines[1] as HTMLElement).style.opacity = '0';
      (lines[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)';
    } else {
      (lines[0] as HTMLElement).style.transform = '';
      (lines[1] as HTMLElement).style.opacity = '';
      (lines[2] as HTMLElement).style.transform = '';
    }
  }

  function closeMenu() {
    menu.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
    (lines[0] as HTMLElement).style.transform = '';
    (lines[1] as HTMLElement).style.opacity = '';
    (lines[2] as HTMLElement).style.transform = '';
  }

  btn.addEventListener('click', toggleMenu);

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeMenu);
  });
</script>
