---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { value: '5', label: t('stats.projects') },
  { value: '10', label: t('stats.aws') },
  { value: '11', label: t('stats.autopost') },
  { value: '~$4.5', label: t('stats.cost') },
];
---

<section class="border-y border-navy-700/50 bg-navy-800/30">
  <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-8">
    {stats.map(({ value, label }) => (
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-accent mb-1">{value}</div>
        <div class="text-slate-400 text-sm">{label}</div>
      </div>
    ))}
  </div>
</section>
