---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const isJa = lang === 'ja';

Astro.response.status = 404;

const title = isJa ? 'ページが見つかりません' : 'Page Not Found';
const message = isJa
  ? 'お探しのページは存在しないか、移動した可能性があります。'
  : 'The page you are looking for does not exist or may have been moved.';
const homeLabel = isJa ? 'ホームへ戻る' : 'Back to Home';
const homeHref = isJa ? '/ja/' : '/en/';
---

<BaseLayout title={title}>
  <div class="max-w-4xl mx-auto px-6 py-32 text-center">
    <div class="text-accent text-8xl font-bold mb-6 opacity-40">404</div>
    <h1 class="text-2xl font-bold text-white mb-4">{title}</h1>
    <p class="text-slate-400 mb-10">{message}</p>
    <a
      href={homeHref}
      class="inline-flex items-center gap-2 px-6 py-3 bg-accent/10 hover:bg-accent/20 text-accent border border-accent/40 hover:border-accent/70 rounded-lg transition-colors"
    >
      ← {homeLabel}
    </a>
  </div>
</BaseLayout>
