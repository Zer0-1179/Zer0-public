---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCategoriesWithTemplates, getTemplatesByCategory } from '../../../../data/templates';
import { useTranslations } from '../../../../i18n/utils';

const t = useTranslations('en');

const { category } = Astro.params;

const allCategories = getCategoriesWithTemplates().map((cat) => ({
  ...cat,
  files: getTemplatesByCategory(cat.slug),
}));

const cat = allCategories.find((c) => c.slug === category);
if (!cat || cat.files.length === 0) return Astro.redirect('/en/templates/');
---

<BaseLayout title={`${cat.labelEn} | ${t('templates.title')}`}>
  <div class="max-w-5xl mx-auto px-6 py-12">

    <!-- Explorer: left nav + right content -->
    <div
      class="flex border border-navy-700/50 rounded-xl overflow-hidden"
      style="height:680px"
    >
      <!-- ── Left navigation pane ── -->
      <div
        id="nav-tree"
        data-current={cat.slug}
        class="w-56 shrink-0 border-r border-navy-700/50 overflow-y-auto bg-navy-900/30 flex flex-col"
      >
        <!-- Nav header: link back to index -->
        <a
          href="/en/templates/"
          class="flex items-center gap-2 px-3 py-2.5 border-b border-navy-700/40 bg-navy-900/50 hover:bg-navy-800/60 transition-colors shrink-0 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent/60 group-hover:text-accent transition-colors shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
          </svg>
          <span class="font-mono text-xs text-slate-400 group-hover:text-white transition-colors">templates</span>
        </a>

        <!-- Tree rows -->
        <div class="flex-1 overflow-y-auto py-1">
          {allCategories.map((c) => (
            <div class="folder-group" data-slug={c.slug}>

              <!-- Folder row: chevron toggle + category link -->
              <div class="flex items-center hover:bg-navy-700/20 transition-colors">
                <button
                  class="folder-toggle flex items-center justify-center w-6 h-7 shrink-0 text-slate-600 hover:text-slate-300 transition-colors"
                  aria-label="Expand/Collapse"
                >
                  <svg
                    class="chevron w-2.5 h-2.5 transition-transform duration-150"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                </button>
                <a
                  href={`/en/templates/${c.slug}/`}
                  class:list={[
                    'flex items-center gap-1.5 flex-1 min-w-0 py-1.5 pr-2 transition-colors',
                    c.slug === cat.slug
                      ? 'text-white'
                      : 'text-slate-400 hover:text-white',
                  ]}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-4 h-4 shrink-0', c.slug === cat.slug ? 'text-accent' : 'text-accent/50']} viewBox="0 0 20 20" fill="currentColor">
                    <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                  </svg>
                  <span class="text-xs truncate flex-1">{c.slug}</span>
                  <span class="text-xs text-slate-600 shrink-0">{c.files.length}</span>
                </a>
              </div>

              <!-- File list under this folder -->
              <div class="folder-files hidden">
                {c.files.map((tmpl) => (
                  <button
                    class="file-btn flex items-center gap-1.5 w-full pl-8 pr-2 py-1 text-left hover:bg-navy-700/20 transition-colors group/file"
                    data-filename={tmpl.filename}
                    data-name={tmpl.nameEn}
                    data-short={tmpl.descShortEn}
                    data-desc={tmpl.descEn}
                    data-services={tmpl.services.join(',')}
                  >
                    <svg class="w-3.5 h-3.5 text-slate-600 group-hover/file:text-slate-400 shrink-0 transition-colors" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                    </svg>
                    <span class="file-label font-mono text-xs text-slate-500 group-hover/file:text-slate-200 truncate transition-colors">
                      {tmpl.filename}
                    </span>
                  </button>
                ))}
              </div>

            </div>
          ))}
        </div>
      </div>

      <!-- ── Right content pane ── -->
      <div class="flex-1 overflow-y-auto flex flex-col min-w-0">

        <!-- Breadcrumb bar -->
        <div class="px-4 py-2 border-b border-navy-700/40 bg-navy-900/30 flex items-center justify-between shrink-0">
          <div class="flex items-center gap-1.5 text-sm font-mono min-w-0">
            <a href="/en/templates/" class="text-slate-500 hover:text-accent transition-colors shrink-0">templates</a>
            <span class="text-slate-700 shrink-0">/</span>
            <button id="bc-cat" class="text-slate-300 hover:text-accent transition-colors shrink-0">{cat.slug}</button>
            <span id="bc-sep" class="text-slate-700 hidden shrink-0">/</span>
            <span id="bc-file" class="text-slate-400 hidden truncate max-w-48"></span>
          </div>
          <a
            href={`/api/templates/download/${cat.slug}.zip`}
            download={`cfn-templates-${cat.slug}.zip`}
            class="shrink-0 flex items-center gap-1 px-2 py-1 bg-accent hover:bg-accent-light text-navy-950 text-xs font-semibold rounded transition-colors ml-2"
          >
            <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            ZIP
          </a>
        </div>

        <!-- File table (default) -->
        <div id="file-table" class="flex-1">
          {cat.files.map((tmpl) => (
            <div
              class="file-row flex items-center gap-3 px-4 py-2.5 border-b border-navy-700/15 hover:bg-navy-700/20 cursor-pointer transition-colors group"
              data-filename={tmpl.filename}
              data-name={tmpl.nameEn}
              data-short={tmpl.descShortEn}
              data-desc={tmpl.descEn}
              data-services={tmpl.services.join(',')}
            >
              <svg class="w-4 h-4 text-slate-600 group-hover:text-slate-400 shrink-0 transition-colors" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
              </svg>

              <span class="font-mono text-sm text-slate-200 group-hover:text-accent transition-colors shrink-0 w-56 truncate">
                {tmpl.filename}
              </span>

              <span class="text-slate-500 text-xs flex-1 truncate hidden md:block">
                {tmpl.descShortEn}
              </span>

              <span class="text-slate-600 text-xs shrink-0 hidden sm:block">{tmpl.updatedAt}</span>

              <a
                href={`/api/templates/${tmpl.filename}`}
                download={tmpl.filename}
                onclick="event.stopPropagation()"
                title="Download"
                class="shrink-0 p-1.5 text-slate-600 hover:text-accent hover:bg-navy-700/40 rounded transition-colors"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          ))}
        </div>

        <!-- YAML viewer (hidden until file selected) -->
        <div id="yaml-viewer" class="hidden flex-1 flex flex-col p-4 gap-3">

          <!-- File header -->
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <svg class="w-4 h-4 text-slate-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                </svg>
                <span id="yv-name" class="font-mono text-accent text-sm font-medium truncate"></span>
              </div>
              <p id="yv-short" class="text-slate-400 text-xs ml-6 leading-relaxed"></p>
              <div id="yv-services" class="flex gap-1 flex-wrap mt-1.5 ml-6"></div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a
                id="yv-dl"
                href="#"
                download
                class="flex items-center gap-1.5 px-3 py-1.5 bg-accent hover:bg-accent-light text-navy-950 text-xs font-semibold rounded transition-colors"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                Download
              </a>
            </div>
          </div>

          <!-- Description -->
          <div class="px-3 py-2.5 bg-navy-900/40 border border-navy-700/30 rounded-lg">
            <p id="yv-desc" class="text-slate-400 text-xs leading-relaxed"></p>
          </div>

          <!-- Code block -->
          <div class="border border-navy-700/50 rounded-lg overflow-hidden flex-1 flex flex-col">
            <div class="px-4 py-2 border-b border-navy-700/40 bg-navy-900/50 flex items-center justify-between shrink-0">
              <span id="yv-filename" class="text-xs text-slate-500 font-mono"></span>
              <button
                id="yv-copy"
                class="px-2.5 py-1 border border-navy-700/50 text-slate-400 text-xs rounded hover:text-white hover:border-navy-600 transition-colors font-mono"
              >
                Copy
              </button>
            </div>
            <pre id="yv-content" class="flex-1 text-xs font-mono text-slate-300 p-4 leading-relaxed overflow-auto whitespace-pre"></pre>
          </div>

        </div>

      </div>
    </div>

  </div>
</BaseLayout>

<script>
  const navTree = document.getElementById('nav-tree') as HTMLElement;
  const currentSlug = navTree.dataset.current!;

  const currentGroup = navTree.querySelector(`.folder-group[data-slug="${currentSlug}"]`);
  if (currentGroup) {
    (currentGroup.querySelector('.folder-files') as HTMLElement).classList.remove('hidden');
    const chev = currentGroup.querySelector('.chevron') as HTMLElement | null;
    if (chev) chev.style.transform = 'rotate(90deg)';
  }

  navTree.querySelectorAll('.folder-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const group = (btn as HTMLElement).closest('.folder-group')!;
      const files   = group.querySelector('.folder-files') as HTMLElement;
      const chevron = group.querySelector('.chevron') as HTMLElement;
      const isOpen  = !files.classList.contains('hidden');
      files.classList.toggle('hidden', isOpen);
      chevron.style.transform = isOpen ? '' : 'rotate(90deg)';
    });
  });

  const fileTable  = document.getElementById('file-table')!;
  const yamlViewer = document.getElementById('yaml-viewer')!;
  const bcCat      = document.getElementById('bc-cat')!;
  const bcSep      = document.getElementById('bc-sep')!;
  const bcFile     = document.getElementById('bc-file')!;
  const yvName     = document.getElementById('yv-name')!;
  const yvShort    = document.getElementById('yv-short')!;
  const yvDesc     = document.getElementById('yv-desc')!;
  const yvServices = document.getElementById('yv-services')!;
  const yvFilename = document.getElementById('yv-filename')!;
  const yvDl       = document.getElementById('yv-dl') as HTMLAnchorElement;
  const yvContent  = document.getElementById('yv-content')!;
  const yvCopy     = document.getElementById('yv-copy')!;
  let activeFileBtn: Element | null = null;

  function setNavActive(filename: string) {
    if (activeFileBtn) {
      activeFileBtn.classList.remove('bg-accent/10');
      activeFileBtn.querySelector('.file-label')?.classList.remove('text-accent');
    }
    const btn = navTree.querySelector(`.file-btn[data-filename="${filename}"]`);
    if (btn) {
      btn.classList.add('bg-accent/10');
      btn.querySelector('.file-label')?.classList.add('text-accent');
      const group   = btn.closest('.folder-group')!;
      const files   = group.querySelector('.folder-files') as HTMLElement;
      const chevron = group.querySelector('.chevron') as HTMLElement | null;
      if (files.classList.contains('hidden')) {
        files.classList.remove('hidden');
        if (chevron) chevron.style.transform = 'rotate(90deg)';
      }
    }
    activeFileBtn = btn;
  }

  function showYaml(filename: string, name: string, short: string, desc: string, services: string) {
    bcSep.classList.remove('hidden');
    bcFile.classList.remove('hidden');
    bcFile.textContent = filename;
    fileTable.classList.add('hidden');
    yamlViewer.classList.remove('hidden');
    yvName.textContent     = filename;
    yvFilename.textContent = filename;
    yvShort.textContent    = short;
    yvDesc.textContent     = desc;
    yvDl.href     = '/api/templates/' + filename;
    yvDl.download = filename;
    yvServices.innerHTML = '';
    (services || '').split(',').filter(Boolean).forEach((svc) => {
      const span = document.createElement('span');
      span.className = 'px-1.5 py-0.5 bg-navy-700/60 text-slate-500 text-xs rounded';
      span.textContent = svc;
      yvServices.appendChild(span);
    });
    setNavActive(filename);
    (yamlViewer.closest('.overflow-y-auto') as HTMLElement).scrollTop = 0;
    yvContent.textContent = 'Loading...';
    fetch('/api/templates/' + filename)
      .then((r) => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
      .then((txt) => { yvContent.textContent = txt; })
      .catch((e) => { yvContent.textContent = 'Error: ' + e.message; });
  }

  function showFileTable() {
    yamlViewer.classList.add('hidden');
    fileTable.classList.remove('hidden');
    bcSep.classList.add('hidden');
    bcFile.classList.add('hidden');
    bcFile.textContent = '';
    if (activeFileBtn) {
      activeFileBtn.classList.remove('bg-accent/10');
      activeFileBtn.querySelector('.file-label')?.classList.remove('text-accent');
      activeFileBtn = null;
    }
  }

  document.querySelectorAll('.file-row').forEach((row) => {
    row.addEventListener('click', () => {
      const el = row as HTMLElement;
      showYaml(el.dataset.filename!, el.dataset.name!, el.dataset.short!, el.dataset.desc!, el.dataset.services!);
    });
  });

  navTree.querySelectorAll('.file-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      showYaml(el.dataset.filename!, el.dataset.name!, el.dataset.short!, el.dataset.desc!, el.dataset.services!);
    });
  });

  bcCat.addEventListener('click', showFileTable);

  yvCopy.addEventListener('click', () => {
    const text = yvContent.textContent;
    if (!text || text === 'Loading...') return;
    const done = () => {
      yvCopy.textContent = 'Copied!';
      setTimeout(() => { yvCopy.textContent = 'Copy'; }, 2000);
    };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(done);
    } else {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      done();
    }
  });
</script>
