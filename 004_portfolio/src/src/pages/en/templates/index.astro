---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { templates } from '../../../data/templates';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
const BASE_URL = 'https://www.zer0-infra.com/downloads';

const categories = [...new Set(templates.map((tmpl) => tmpl.categoryEn))];
const grouped = categories.map((cat) => ({
  label: cat,
  items: templates.filter((tmpl) => tmpl.categoryEn === cat),
}));
---

<BaseLayout title={t('templates.title')}>
  <div class="max-w-5xl mx-auto px-6 py-20">

    <div class="mb-10">
      <h1 class="text-4xl font-bold text-white mb-2">{t('templates.title')}</h1>
      <div class="w-12 h-0.5 bg-accent mb-4"></div>
      <p class="text-slate-400">{t('templates.sub')}</p>
    </div>

    <!-- README block -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden mb-10">
      <div class="px-4 py-2.5 border-b border-navy-700/50 bg-navy-800/60 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm text-slate-400 font-mono">README</span>
      </div>
      <div class="px-6 py-5">
        <p class="text-sm font-semibold text-slate-300 mb-3">{t('templates.readme')}</p>
        <p class="text-sm text-slate-400 leading-relaxed">{t('templates.readme.body')}</p>
      </div>
    </div>

    <!-- File list grouped by category -->
    {grouped.map(({ label, items }) => (
      <div class="mb-8">
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-2 px-1">
          {label} <span class="ml-1 text-slate-600 normal-case tracking-normal font-normal">{items.length}</span>
        </h2>
        <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden">
          {items.map((tmpl, i) => (
            <div class={`flex items-center gap-3 px-4 py-3 hover:bg-navy-700/20 transition-colors group ${i < items.length - 1 ? 'border-b border-navy-700/30' : ''}`}>
              <!-- YAML file icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
              </svg>

              <!-- filename -->
              <span class="font-mono text-sm text-accent shrink-0 w-56 truncate group-hover:text-accent-light transition-colors">
                {tmpl.filename}
              </span>

              <!-- short description -->
              <span class="text-slate-400 text-sm flex-1 truncate hidden sm:block">
                {tmpl.descShortEn}
              </span>

              <!-- service tags -->
              <div class="hidden lg:flex items-center gap-1 shrink-0">
                {tmpl.services.map((svc) => (
                  <span class="px-1.5 py-0.5 bg-navy-700/60 text-slate-500 text-xs rounded">{svc}</span>
                ))}
              </div>

              <!-- updated date -->
              <span class="text-slate-600 text-xs shrink-0 hidden md:block w-24 text-right">
                {tmpl.updatedAt}
              </span>

              <!-- download button -->
              <a
                href={`${BASE_URL}/${tmpl.filename}`}
                download={tmpl.filename}
                title={t('templates.download')}
                class="flex items-center gap-1.5 px-3 py-1.5 bg-accent hover:bg-accent-light text-navy-950 text-xs font-semibold rounded transition-colors shrink-0"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                <span class="hidden sm:inline">{t('templates.download')}</span>
              </a>
            </div>
          ))}
        </div>
      </div>
    ))}

  </div>
</BaseLayout>
