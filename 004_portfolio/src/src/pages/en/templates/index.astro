---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCategoriesWithTemplates, getTemplatesByCategory } from '../../../data/templates';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
const categoriesWithTemplates = getCategoriesWithTemplates().map((cat) => ({
  ...cat,
  count: getTemplatesByCategory(cat.slug).length,
}));
---

<BaseLayout title={t('templates.title')}>
  <div class="max-w-5xl mx-auto px-6 py-20">

    <div class="mb-10">
      <h1 class="text-4xl font-bold text-white mb-2">{t('templates.title')}</h1>
      <div class="w-12 h-0.5 bg-accent mb-4"></div>
      <p class="text-slate-400">{t('templates.sub')}</p>
    </div>

    <!-- Folder list -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden mb-8">
      {categoriesWithTemplates.map((cat, i) => (
        <a
          href={`/en/templates/${cat.slug}/`}
          class={`flex items-center gap-3 px-4 py-3.5 hover:bg-navy-700/20 transition-colors group ${i < categoriesWithTemplates.length - 1 ? 'border-b border-navy-700/30' : ''}`}
        >
          <!-- folder icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent/70 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
          </svg>

          <!-- folder name -->
          <span class="font-mono text-sm text-white shrink-0 w-44 group-hover:text-accent transition-colors">
            {cat.labelEn}
          </span>

          <!-- description -->
          <span class="text-slate-400 text-sm flex-1 truncate hidden sm:block">
            {cat.descEn}
          </span>

          <!-- file count -->
          <span class="text-slate-500 text-xs shrink-0">
            {cat.count} {t('templates.files')}
          </span>

          <!-- chevron -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-600 group-hover:text-slate-400 transition-colors shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        </a>
      ))}
    </div>

    <!-- README block -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden mb-8">
      <div class="px-4 py-2.5 border-b border-navy-700/50 bg-navy-800/60 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm text-slate-400 font-mono">README</span>
      </div>
      <div class="px-6 py-6 space-y-5 text-sm">
        <div>
          <p class="font-semibold text-slate-200 mb-1">{t('templates.readme')}</p>
          <p class="text-slate-400 leading-relaxed">
            CloudFormation templates extracted from real production projects and generalized for public use.
            Each template is ready to deploy as-is — just supply your parameters.
          </p>
        </div>

        <div>
          <p class="font-semibold text-slate-300 mb-2">Design Principles</p>
          <ul class="space-y-1 text-slate-400">
            <li class="flex gap-2"><span class="text-accent shrink-0">•</span>No hardcoding — all configurable values are exposed as <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Parameters</code></li>
            <li class="flex gap-2"><span class="text-accent shrink-0">•</span><code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Env</code> parameter auto-switches stg / dev / prd settings (retention, DeletionPolicy, etc.)</li>
            <li class="flex gap-2"><span class="text-accent shrink-0">•</span>Least-privilege IAM and optional KMS encryption pre-configured</li>
            <li class="flex gap-2"><span class="text-accent shrink-0">•</span>Cross-stack references via <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Outputs</code> + <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">ImportValue</code></li>
          </ul>
        </div>

        <div>
          <p class="font-semibold text-slate-300 mb-2">How to Deploy</p>
          <pre class="bg-navy-900/60 border border-navy-700/50 rounded-lg px-4 py-3 text-xs text-slate-300 font-mono overflow-x-auto leading-relaxed">aws cloudformation deploy \
  --stack-name &lt;stack-name&gt; \
  --template-file &lt;template&gt;.yaml \
  --capabilities CAPABILITY_NAMED_IAM \
  --parameter-overrides ProjectName=&lt;name&gt; Env=prd</pre>
        </div>

        <div class="flex gap-2 text-slate-400">
          <span class="text-yellow-500/80 shrink-0">⚠</span>
          <p>Resources deployed with <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Env=prd</code> have <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">DeletionPolicy: Retain</code> set. Deleting the stack does not delete the underlying resources — remove them manually via the AWS Console or CLI when no longer needed.</p>
        </div>
      </div>
    </div>

    <!-- Naming Convention block -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden">
      <div class="px-4 py-2.5 border-b border-navy-700/50 bg-navy-800/60 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm text-slate-400 font-mono">Naming Convention</span>
      </div>
      <div class="px-6 py-6 text-sm space-y-6">

        <!-- yaml file names -->
        <div>
          <p class="font-semibold text-slate-300 mb-2">Template File Names</p>
          <p class="text-slate-400 mb-2">Omit Type when only one template exists for the service:</p>
          <pre class="bg-navy-900/60 border border-navy-700/50 rounded-lg px-4 py-3 text-xs text-accent font-mono overflow-x-auto">cfn-{"{Service}"}.yaml　　　　　 # e.g. cfn-s3.yaml
cfn-{"{Service}"}-{"{Type}"}.yaml　　 # e.g. cfn-ecs-cluster.yaml</pre>
        </div>

        <!-- resource names -->
        <div>
          <p class="font-semibold text-slate-300 mb-2">Resource Names (Suffix is optional)</p>
          <pre class="bg-navy-900/60 border border-navy-700/50 rounded-lg px-4 py-3 text-xs text-accent font-mono overflow-x-auto">{"{ProjectName}"}-{"{Env}"}-{"{Service}"}-{"{Suffix}"}</pre>
        </div>

        <!-- table -->
        <div class="overflow-x-auto">
          <table class="w-full text-xs border-collapse">
            <thead>
              <tr class="border-b border-navy-700/50 text-left">
                <th class="pb-2 pr-6 text-slate-400 font-medium">Service</th>
                <th class="pb-2 pr-6 text-slate-400 font-medium">File Name</th>
                <th class="pb-2 text-slate-400 font-medium">Resource Name Example (pj / dev)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-navy-700/20">
              <tr><td class="py-1.5 pr-6 text-slate-300">VPC</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-vpc.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-vpc</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">Internet Gateway</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-igw.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-igw</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">NAT Gateway</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-nat.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-nat</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">Security Group</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-security-group.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-sg-web</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">ALB</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-alb.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-alb-01</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">NLB</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-nlb.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-nlb-01</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">EC2</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-ec2.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-ec2-web</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">ECS Cluster</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-ecs-cluster.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-ecs-cluster</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">ECS Service</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-ecs-service.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-ecs-api</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">ECR</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-ecr.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-ecr-app</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">Lambda</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-lambda.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-lambda-api</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">S3</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-s3.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-s3-assets</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">EFS</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-efs.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-efs-shared</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">EBS</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-ebs.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-ebs-data</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">RDS</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-rds.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-rds</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">DynamoDB</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-dynamodb.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-dynamodb-users</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">SQS</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-sqs.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-sqs-orders</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">KMS</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-kms.yaml</td><td class="py-1.5 font-mono text-slate-400">alias/pj-dev-kms</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">IAM Role</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-iam-role.yaml</td><td class="py-1.5 font-mono text-slate-400">pj-dev-lambda-role</td></tr>
              <tr><td class="py-1.5 pr-6 text-slate-300">CloudWatch Logs</td><td class="py-1.5 pr-6 font-mono text-slate-500">cfn-cw-logs.yaml</td><td class="py-1.5 font-mono text-slate-400">/aws/lambda/pj-dev-lambda-api</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
