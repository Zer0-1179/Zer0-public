---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import StatsBar from '../../components/StatsBar.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { projects } from '../../data/projects';
import { templates } from '../../data/templates';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
const featured = projects.filter((p) => p.featured);

type Article = { title: string; link: string; date: string; source: 'zenn' | 'note' };
let articles: Article[] = [];
try {
  const [zennRes, noteRes] = await Promise.allSettled([
    fetch('https://zenn.dev/zer0_infra/feed'),
    fetch('https://note.com/zer0_infra/rss'),
  ]);
  const parseRss = (xml: string, source: 'zenn' | 'note'): Article[] => {
    const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];
    return items.slice(0, 3).map((m) => {
      const title = m[1].match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/)?.[1] ?? m[1].match(/<title>(.*?)<\/title>/)?.[1] ?? '';
      const link = m[1].match(/<link>(.*?)<\/link>/)?.[1] ?? '';
      const date = m[1].match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? new Date().toISOString();
      return { title, link, date, source };
    });
  };
  if (zennRes.status === 'fulfilled' && zennRes.value.ok) articles.push(...parseRss(await zennRes.value.text(), 'zenn'));
  if (noteRes.status === 'fulfilled' && noteRes.value.ok) articles.push(...parseRss(await noteRes.value.text(), 'note'));
} catch {}
---

<BaseLayout title={t('nav.home')}>
  <Hero />
  <StatsBar />

  <section class="max-w-6xl mx-auto px-6 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-white">{t('section.projects')}</h2>
        <p class="text-slate-400 mt-1 text-sm">{t('section.projects.sub')}</p>
      </div>
      <a href="/en/projects/" class="text-accent text-sm hover:text-accent-light transition-colors hidden md:block">All Projects →</a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {featured.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>

  <!-- Templates CTA -->
  <section class="max-w-6xl mx-auto px-6 py-12 border-t border-navy-700/30">
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl p-5 flex flex-col sm:flex-row items-start sm:items-center gap-5">
      <div class="p-2.5 bg-accent/10 border border-accent/20 rounded-lg shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 20 20" fill="currentColor">
          <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-white font-semibold text-sm">{t('templates.cta.title')}</p>
        <p class="text-slate-400 text-xs mt-0.5">
          {t('templates.cta.sub')}
          <span class="text-slate-500 ml-1">{templates.length} templates available</span>
        </p>
      </div>
      <a href="/en/templates/" class="px-4 py-2 border border-accent text-accent text-xs font-semibold rounded hover:bg-accent hover:text-navy-950 transition-colors shrink-0">
        {t('templates.cta.link')}
      </a>
    </div>
  </section>

  {articles.length > 0 && (
    <section class="max-w-6xl mx-auto px-6 py-12 border-t border-navy-700/30">
      <div class="flex items-end justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold text-white">{t('section.articles')}</h2>
          <p class="text-slate-400 mt-1 text-sm">{t('section.articles.sub')}</p>
        </div>
        <a href="/en/articles/" class="text-accent text-sm hover:text-accent-light transition-colors hidden md:block">All Articles →</a>
      </div>
      <div class="bg-navy-800/30 border border-navy-700/40 rounded-lg px-4">
        {articles.map((a) => <ArticleCard {...a} />)}
      </div>
    </section>
  )}
</BaseLayout>
