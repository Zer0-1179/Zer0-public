---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCategoriesWithTemplates, getTemplatesByCategory } from '../../../data/templates';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('ja');
const categoriesWithTemplates = getCategoriesWithTemplates().map((cat) => ({
  ...cat,
  count: getTemplatesByCategory(cat.slug).length,
}));
---

<BaseLayout title={t('templates.title')}>
  <div class="max-w-5xl mx-auto px-6 py-20">

    <div class="mb-10">
      <h1 class="text-4xl font-bold text-white mb-2">{t('templates.title')}</h1>
      <div class="w-12 h-0.5 bg-accent mb-4"></div>
      <p class="text-slate-400">{t('templates.sub')}</p>
    </div>

    <!-- README block -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden mb-8">
      <div class="px-4 py-2.5 border-b border-navy-700/50 bg-navy-800/60 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
        </svg>
        <span class="text-sm text-slate-400 font-mono">README</span>
      </div>
      <div class="px-6 py-5">
        <p class="text-sm font-semibold text-slate-300 mb-3">{t('templates.readme')}</p>
        <p class="text-sm text-slate-400 leading-relaxed">{t('templates.readme.body')}</p>
      </div>
    </div>

    <!-- Folder list -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden">
      {categoriesWithTemplates.map((cat, i) => (
        <a
          href={`/ja/templates/${cat.slug}/`}
          class={`flex items-center gap-3 px-4 py-3.5 hover:bg-navy-700/20 transition-colors group ${i < categoriesWithTemplates.length - 1 ? 'border-b border-navy-700/30' : ''}`}
        >
          <!-- folder icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent/70 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
          </svg>

          <!-- folder name -->
          <span class="font-mono text-sm text-white shrink-0 w-44 group-hover:text-accent transition-colors">
            {cat.labelJa}
          </span>

          <!-- description -->
          <span class="text-slate-400 text-sm flex-1 truncate hidden sm:block">
            {cat.descJa}
          </span>

          <!-- file count -->
          <span class="text-slate-500 text-xs shrink-0">
            {cat.count}{t('templates.files')}
          </span>

          <!-- chevron -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-600 group-hover:text-slate-400 transition-colors shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
