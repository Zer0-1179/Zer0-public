---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCategoriesWithTemplates, getTemplatesByCategory } from '../../../data/templates';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('ja');

const categories = getCategoriesWithTemplates().map((cat) => ({
  ...cat,
  files: getTemplatesByCategory(cat.slug),
  count: getTemplatesByCategory(cat.slug).length,
}));

const totalFiles = categories.reduce((s, c) => s + c.count, 0);
---

<BaseLayout title={t('templates.title')}>
  <div class="max-w-5xl mx-auto px-6 py-12">

    <div class="mb-8">
      <h1 class="text-4xl font-bold text-white mb-2">{t('templates.title')}</h1>
      <div class="w-12 h-0.5 bg-accent mb-4"></div>
      <p class="text-slate-400">{t('templates.sub')}</p>
    </div>

    <!-- Explorer: left nav tree + right content -->
    <div
      id="templates-explorer"
      data-lang="ja"
      class="flex border border-navy-700/50 rounded-xl overflow-hidden"
      style="height:680px"
    >

      <!-- ── Left navigation tree ── -->
      <div class="w-64 shrink-0 border-r border-navy-700/50 overflow-y-auto bg-navy-900/30 flex flex-col">

        <!-- Root header -->
        <div class="flex items-center justify-between px-3 py-2.5 border-b border-navy-700/40 bg-navy-900/50 shrink-0">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-accent/70" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
            </svg>
            <span class="font-mono text-xs text-white">templates</span>
            <span class="text-slate-600 text-xs">{totalFiles}</span>
          </div>
          <a
            href="/api/templates/download/all.zip"
            download="cfn-templates-all.zip"
            title="すべてダウンロード"
            class="p-1.5 text-slate-500 hover:text-accent hover:bg-navy-700/40 transition-colors rounded"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>

        <!-- Tree rows -->
        <div class="flex-1 overflow-y-auto py-1">
          {categories.map((cat) => (
            <div class="folder-group" data-slug={cat.slug}>

              <!-- Folder row: whole row toggles expand/collapse -->
              <div class="folder-toggle-row flex items-center hover:bg-navy-700/20 transition-colors cursor-pointer select-none group/folder">
                <div class="flex items-center justify-center w-6 h-7 shrink-0 text-slate-600">
                  <svg class="chevron w-2.5 h-2.5 transition-transform duration-150" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="flex items-center gap-1.5 flex-1 min-w-0 py-1.5 text-slate-400">
                  <svg class="w-4 h-4 text-accent/50 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
                  </svg>
                  <span class="text-xs truncate flex-1 text-slate-300">{cat.slug}</span>
                  <span class="text-xs text-slate-600 shrink-0">{cat.count}</span>
                </div>
                <a
                  href={`/api/templates/download/${cat.slug}.zip`}
                  download={`cfn-templates-${cat.slug}.zip`}
                  title={`${cat.slug} をZIPダウンロード`}
                  onclick="event.stopPropagation()"
                  class="w-6 h-7 flex items-center justify-center shrink-0 text-slate-700 hover:text-accent transition-colors opacity-0 group-hover/folder:opacity-100"
                >
                  <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>

              <!-- File list under folder -->
              <div class="folder-files hidden">
                {cat.files.map((tmpl) => (
                  <button
                    class="file-btn flex items-center gap-1.5 w-full pl-8 pr-2 py-1 text-left hover:bg-navy-700/20 transition-colors group/file"
                    data-filename={tmpl.filename}
                    data-name={tmpl.nameJa}
                    data-short={tmpl.descShortJa}
                    data-desc={tmpl.descJa}
                    data-services={tmpl.services.join(',')}
                  >
                    <svg class="w-3.5 h-3.5 text-slate-600 group-hover/file:text-slate-400 shrink-0 transition-colors" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                    </svg>
                    <span class="file-label font-mono text-xs text-slate-500 group-hover/file:text-slate-200 truncate transition-colors">
                      {tmpl.filename}
                    </span>
                  </button>
                ))}
              </div>

            </div>
          ))}
        </div>
      </div>

      <!-- ── Right content pane ── -->
      <div class="flex-1 overflow-y-auto flex flex-col min-w-0">

        <!-- Tab bar -->
        <div class="sticky top-0 z-10 flex items-center border-b border-navy-700/40 bg-navy-900/50 shrink-0">
          <button
            id="tab-readme"
            class="flex items-center gap-1.5 px-3 py-2 text-xs font-mono border-b-2 border-accent text-white transition-colors"
          >
            <svg class="w-3.5 h-3.5 text-slate-400 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
            </svg>
            README.md
          </button>
          <button
            id="tab-file"
            class="hidden flex items-center gap-1.5 px-3 py-2 text-xs font-mono border-b-2 border-transparent text-slate-400 hover:text-white transition-colors"
          >
            <svg class="w-3.5 h-3.5 text-slate-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
            </svg>
            <span id="tab-file-name" class="max-w-40 truncate"></span>
            <span id="tab-close" class="ml-1 text-slate-500 hover:text-white transition-colors">×</span>
          </button>
        </div>

        <!-- README (default) -->
        <div id="readme-panel" class="flex-1 px-6 py-5 space-y-5 text-sm">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <svg class="w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
              </svg>
              <span class="font-mono text-sm text-slate-400">README.md</span>
            </div>
            <p class="font-semibold text-slate-200 mb-1">{t('templates.readme')}</p>
            <p class="text-slate-400 leading-relaxed">
              実際の運用プロジェクトで使用している CloudFormation テンプレートを汎用化して公開しています。
              パラメータを指定するだけでそのままデプロイできる状態に整備済みです。
            </p>
          </div>
          <div>
            <p class="font-semibold text-slate-300 mb-2">設計方針</p>
            <ul class="space-y-1 text-slate-400">
              <li class="flex gap-2"><span class="text-accent shrink-0">•</span>ハードコードなし — 変更が想定される値はすべて <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Parameters</code> に外出し</li>
              <li class="flex gap-2"><span class="text-accent shrink-0">•</span><code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Env</code> パラメータで stg / dev / prd 設定を自動切替（保持期間・DeletionPolicy など）</li>
              <li class="flex gap-2"><span class="text-accent shrink-0">•</span>最小権限 IAM・KMS 暗号化オプション設定済み</li>
              <li class="flex gap-2"><span class="text-accent shrink-0">•</span>スタック間参照は <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">Outputs</code> + <code class="text-accent/80 bg-navy-700/60 px-1 rounded text-xs">ImportValue</code> で対応</li>
            </ul>
          </div>
          <div>
            <p class="font-semibold text-slate-300 mb-2">命名規則</p>
            <pre class="bg-navy-900/60 border border-navy-700/50 rounded-lg px-4 py-3 text-xs text-slate-300 font-mono overflow-x-auto leading-relaxed">テンプレートファイル名:
  cfn-&#123;Service&#125;.yaml            # 例: cfn-s3.yaml
  cfn-&#123;Service&#125;-&#123;Type&#125;.yaml     # 例: cfn-ecs-cluster.yaml

スタック名:
  &#123;ProjectName&#125;-&#123;Env&#125;-&#123;Service&#125;
  &#123;ProjectName&#125;-&#123;Env&#125;-&#123;Service&#125;-&#123;Suffix&#125;

リソース名:
  &#123;ProjectName&#125;-&#123;Env&#125;-&#123;Service&#125;-&#123;Suffix&#125;</pre>
            <div class="mt-2 overflow-x-auto">
              <table class="text-xs w-full border-collapse">
                <thead>
                  <tr class="border-b border-navy-700/50">
                    <th class="text-left text-slate-400 font-normal py-1 pr-4">サービス</th>
                    <th class="text-left text-slate-400 font-normal py-1">リソース名例（pj-dev-...）</th>
                  </tr>
                </thead>
                <tbody class="text-slate-500">
                  {[
                    ['VPC', 'pj-dev-vpc'],
                    ['NAT Gateway', 'pj-dev-ngw'],
                    ['Security Group', 'pj-dev-sg-web'],
                    ['ALB', 'pj-dev-alb-01'],
                    ['EC2', 'pj-dev-ec2'],
                    ['Lambda', 'pj-dev-lambda-api'],
                    ['ECS Cluster', 'pj-dev-ecs-cluster'],
                    ['ECS Service', 'pj-dev-ecs-api'],
                    ['S3', 'pj-dev-s3-assets'],
                    ['RDS', 'pj-dev-rds'],
                    ['DynamoDB', 'pj-dev-dynamodb-users'],
                    ['SQS', 'pj-dev-sqs-orders'],
                    ['KMS', 'alias/pj-dev-kms'],
                    ['IAM Role', 'pj-dev-lambda-role'],
                  ].map(([svc, ex]) => (
                    <tr class="border-b border-navy-700/20">
                      <td class="py-1 pr-4 text-slate-400">{svc}</td>
                      <td class="py-1 font-mono text-accent/70">{ex}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
          <div>
            <p class="font-semibold text-slate-300 mb-2">デプロイ方法</p>
            <pre class="bg-navy-900/60 border border-navy-700/50 rounded-lg px-4 py-3 text-xs text-slate-300 font-mono overflow-x-auto leading-relaxed">aws cloudformation deploy \
  --stack-name &lt;stack-name&gt; \
  --template-file &lt;template&gt;.yaml \
  --capabilities CAPABILITY_NAMED_IAM \
  --parameter-overrides ProjectName=&lt;name&gt; Env=prd</pre>
          </div>
          <div class="flex gap-2 text-slate-400 text-xs">
            <span class="text-yellow-500/80 shrink-0">⚠</span>
            <p><code class="text-accent/80 bg-navy-700/60 px-1 rounded">Env=prd</code> でデプロイしたリソースは <code class="text-accent/80 bg-navy-700/60 px-1 rounded">DeletionPolicy: Retain</code> が設定されています。スタックを削除してもリソースは残るため、不要になった場合は AWS コンソールまたは CLI から手動で削除してください。</p>
          </div>
        </div>

        <!-- YAML viewer (hidden until file selected) -->
        <div id="yaml-viewer" class="hidden flex-1 flex flex-col p-4 gap-3">

          <!-- File header -->
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <svg class="w-4 h-4 text-slate-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
                </svg>
                <span id="yv-name" class="font-mono text-accent text-sm font-medium truncate"></span>
              </div>
              <p id="yv-short" class="text-slate-400 text-xs ml-6 leading-relaxed"></p>
              <div id="yv-services" class="flex gap-1 flex-wrap mt-1.5 ml-6"></div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <a
                id="yv-dl"
                href="#"
                download
                class="flex items-center gap-1.5 px-3 py-1.5 bg-accent hover:bg-accent-light text-navy-950 text-xs font-semibold rounded transition-colors"
              >
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                ダウンロード
              </a>
            </div>
          </div>

          <!-- Description -->
          <div class="px-3 py-2.5 bg-navy-900/40 border border-navy-700/30 rounded-lg">
            <p id="yv-desc" class="text-slate-400 text-xs leading-relaxed"></p>
          </div>

          <!-- Code block -->
          <div class="border border-navy-700/50 rounded-lg overflow-hidden flex-1 flex flex-col">
            <div class="px-4 py-2 border-b border-navy-700/40 bg-navy-900/50 flex items-center justify-between shrink-0">
              <span id="yv-filename" class="text-xs text-slate-500 font-mono"></span>
              <button
                id="yv-copy"
                class="px-2.5 py-1 border border-navy-700/50 text-slate-400 text-xs rounded hover:text-white hover:border-navy-600 transition-colors font-mono"
              >
                コピー
              </button>
            </div>
            <pre id="yv-content" class="flex-1 text-xs font-mono text-slate-300 p-4 leading-relaxed overflow-auto whitespace-pre"></pre>
          </div>

        </div>

      </div>
    </div>

  </div>
</BaseLayout>

<script>
  const explorer = document.getElementById('templates-explorer');
  const lang = explorer?.dataset.lang || 'ja';
  const i18n = {
    loading: lang === 'ja' ? '読み込み中...' : 'Loading...',
    error:   lang === 'ja' ? 'エラー: '     : 'Error: ',
    copy:    lang === 'ja' ? 'コピー'        : 'Copy',
    copied:  lang === 'ja' ? 'コピーしました！' : 'Copied!',
  };

  const readmePanel  = document.getElementById('readme-panel');
  const yamlViewer   = document.getElementById('yaml-viewer');
  const tabReadme    = document.getElementById('tab-readme')!;
  const tabFile      = document.getElementById('tab-file')!;
  const tabFileName  = document.getElementById('tab-file-name')!;
  const tabClose     = document.getElementById('tab-close')!;
  const yvName       = document.getElementById('yv-name');
  const yvShort      = document.getElementById('yv-short');
  const yvDesc       = document.getElementById('yv-desc');
  const yvServices   = document.getElementById('yv-services');
  const yvFilename   = document.getElementById('yv-filename');
  const yvDl         = document.getElementById('yv-dl');
  const yvContent    = document.getElementById('yv-content');
  const yvCopy       = document.getElementById('yv-copy');
  let activeFileBtn: Element | null = null;

  function setActiveTab(which: 'readme' | 'file') {
    const isReadme = which === 'readme';
    tabReadme.classList.toggle('border-accent', isReadme);
    tabReadme.classList.toggle('text-white', isReadme);
    tabReadme.classList.toggle('border-transparent', !isReadme);
    tabReadme.classList.toggle('text-slate-400', !isReadme);
    tabFile.classList.toggle('border-accent', !isReadme);
    tabFile.classList.toggle('text-white', !isReadme);
    tabFile.classList.toggle('border-transparent', isReadme);
    tabFile.classList.toggle('text-slate-400', isReadme);
    readmePanel!.classList.toggle('hidden', !isReadme);
    yamlViewer!.classList.toggle('hidden', isReadme);
  }

  // Folder row click → expand/collapse
  document.querySelectorAll('.folder-toggle-row').forEach((row) => {
    row.addEventListener('click', () => {
      const group = row.closest('.folder-group');
      if (!group) return;
      const files   = group.querySelector('.folder-files') as HTMLElement;
      const chevron = group.querySelector('.chevron') as HTMLElement;
      const isOpen  = !files.classList.contains('hidden');
      files.classList.toggle('hidden', isOpen);
      chevron.style.transform = isOpen ? '' : 'rotate(90deg)';
    });
  });

  function setNavActive(filename: string) {
    if (activeFileBtn) {
      activeFileBtn.classList.remove('bg-accent/10');
      activeFileBtn.querySelector('.file-label')?.classList.remove('text-accent');
    }
    const btn = document.querySelector(`.file-btn[data-filename="${filename}"]`);
    if (btn) {
      btn.classList.add('bg-accent/10');
      btn.querySelector('.file-label')?.classList.add('text-accent');
      const group  = btn.closest('.folder-group');
      const files  = group?.querySelector('.folder-files') as HTMLElement | null;
      const chev   = group?.querySelector('.chevron') as HTMLElement | null;
      if (files?.classList.contains('hidden')) {
        files.classList.remove('hidden');
        if (chev) chev.style.transform = 'rotate(90deg)';
      }
    }
    activeFileBtn = btn;
  }

  function showYaml(filename: string, short: string, desc: string, services: string) {
    tabFileName.textContent = filename;
    tabFile.classList.remove('hidden');
    setActiveTab('file');
    (yamlViewer!.closest('.overflow-y-auto') as HTMLElement).scrollTop = 0;

    yvName!.textContent     = filename;
    yvFilename!.textContent = filename;
    yvShort!.textContent    = short;
    yvDesc!.textContent     = desc;
    (yvDl as HTMLAnchorElement).href     = '/api/templates/' + filename;
    (yvDl as HTMLAnchorElement).download = filename;

    yvServices!.innerHTML = '';
    (services || '').split(',').filter(Boolean).forEach((svc) => {
      const span = document.createElement('span');
      span.className = 'px-1.5 py-0.5 bg-navy-700/60 text-slate-500 text-xs rounded';
      span.textContent = svc;
      yvServices!.appendChild(span);
    });

    setNavActive(filename);

    yvContent!.textContent = i18n.loading;
    fetch('/api/templates/' + filename)
      .then((r) => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.text(); })
      .then((txt) => { yvContent!.textContent = txt; })
      .catch((e) => { yvContent!.textContent = i18n.error + e.message; });
  }

  tabReadme.addEventListener('click', () => setActiveTab('readme'));

  tabFile.addEventListener('click', () => setActiveTab('file'));

  tabClose.addEventListener('click', (e) => {
    e.stopPropagation();
    tabFile.classList.add('hidden');
    setActiveTab('readme');
    if (activeFileBtn) {
      activeFileBtn.classList.remove('bg-accent/10');
      activeFileBtn.querySelector('.file-label')?.classList.remove('text-accent');
      activeFileBtn = null;
    }
  });

  document.querySelectorAll('.file-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      showYaml(el.dataset.filename!, el.dataset.short!, el.dataset.desc!, el.dataset.services!);
    });
  });

  yvCopy!.addEventListener('click', () => {
    const text = yvContent!.textContent;
    if (!text || text === i18n.loading) return;
    const done = () => {
      yvCopy!.textContent = i18n.copied;
      setTimeout(() => { yvCopy!.textContent = i18n.copy; }, 2000);
    };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(done);
    } else {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      done();
    }
  });
</script>
