---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCategoryBySlug, getTemplatesByCategory } from '../../../../data/templates';
import { useTranslations } from '../../../../i18n/utils';

const t = useTranslations('ja');
const BASE_URL = 'https://www.zer0-infra.com/downloads';

const { category } = Astro.params;
const cat = getCategoryBySlug(category!);
if (!cat) return Astro.redirect('/ja/templates/');

const items = getTemplatesByCategory(cat.slug);
if (items.length === 0) return Astro.redirect('/ja/templates/');
---

<BaseLayout title={`${cat.labelJa} | ${t('templates.title')}`}>
  <div class="max-w-5xl mx-auto px-6 py-20">

    <!-- breadcrumb -->
    <div class="mb-8">
      <a href="/ja/templates/" class="text-sm text-slate-500 hover:text-accent transition-colors">
        {t('templates.back')}
      </a>
      <div class="mt-4">
        <div class="flex items-center gap-3 mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent/70" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2 6a2 2 0 012-2h5l2 2h5a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V6z" />
          </svg>
          <h1 class="text-3xl font-bold text-white">{cat.labelJa}</h1>
        </div>
        {cat.descJa && (
          <p class="text-slate-400 text-sm ml-9">{cat.descJa}</p>
        )}
      </div>
    </div>

    <!-- File list -->
    <div class="bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden">
      {items.map((tmpl, i) => (
        <div class={`flex items-center gap-3 px-4 py-3 hover:bg-navy-700/20 transition-colors group ${i < items.length - 1 ? 'border-b border-navy-700/30' : ''}`}>
          <!-- file icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd" />
          </svg>

          <!-- filename -->
          <span class="font-mono text-sm text-accent shrink-0 w-56 truncate group-hover:text-accent-light transition-colors">
            {tmpl.filename}
          </span>

          <!-- short description -->
          <span class="text-slate-400 text-sm flex-1 truncate hidden sm:block">
            {tmpl.descShortJa}
          </span>

          <!-- service tags -->
          <div class="hidden lg:flex items-center gap-1 shrink-0">
            {tmpl.services.map((svc) => (
              <span class="px-1.5 py-0.5 bg-navy-700/60 text-slate-500 text-xs rounded">{svc}</span>
            ))}
          </div>

          <!-- updated date -->
          <span class="text-slate-600 text-xs shrink-0 hidden md:block w-24 text-right">
            {tmpl.updatedAt}
          </span>

          <!-- download button -->
          <a
            href={`${BASE_URL}/${tmpl.filename}`}
            download={tmpl.filename}
            title={t('templates.download')}
            class="flex items-center gap-1.5 px-3 py-1.5 bg-accent hover:bg-accent-light text-navy-950 text-xs font-semibold rounded transition-colors shrink-0"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            <span class="hidden sm:inline">{t('templates.download')}</span>
          </a>
        </div>
      ))}
    </div>

  </div>
</BaseLayout>
