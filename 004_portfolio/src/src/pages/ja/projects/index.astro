---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { projects } from '../../../data/projects';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('ja');
---

<BaseLayout title={t('projects.title')}>
  <div class="max-w-6xl mx-auto px-6 py-20">
    <div class="mb-14">
      <h1 class="text-4xl font-bold text-white mb-2">{t('projects.title')}</h1>
      <div class="w-12 h-0.5 bg-accent mb-4"></div>
      <p class="text-slate-400">{t('projects.sub')}</p>
    </div>

    <!-- 月額運用コスト -->
    <div class="mb-14 bg-navy-800/40 border border-navy-700/50 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-1">月額運用コスト</h2>
      <p class="text-slate-400 text-xs mb-5">このサイト自体は AWS 無料枠内で運用。掲載プロジェクトの合計は約 $4.5/月。</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-navy-700/60">
              <th class="text-left text-slate-400 font-medium pb-2 pr-6">プロジェクト</th>
              <th class="text-right text-slate-400 font-medium pb-2">月額コスト</th>
            </tr>
          </thead>
          <tbody>
            {projects.map((p) => (
              <tr class="border-b border-navy-700/30 last:border-0">
                <td class="py-2 pr-6 text-slate-300">
                  <span class="font-mono text-slate-500 text-xs mr-2">{p.number}</span>{p.nameJa}
                  {p.slug === 'portfolio' && <span class="ml-2 text-xs text-accent">（このサイト）</span>}
                </td>
                <td class={`py-2 text-right font-mono font-semibold ${p.monthlyCost === '$0' ? 'text-accent' : 'text-slate-200'}`}>
                  {p.monthlyCost}
                </td>
              </tr>
            ))}
            <tr class="border-t-2 border-navy-600">
              <td class="pt-3 pr-6 text-slate-300 font-semibold">合計</td>
              <td class="pt-3 text-right font-mono font-bold text-white">~$4.5</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((p) => {
        const name = p.nameJa;
        const desc = p.descJa;
        return (
          <article class="group bg-navy-800/40 border border-navy-700/50 rounded-xl overflow-hidden hover:border-accent/40 transition-all duration-200 flex flex-col">

            <!-- 構成図プレビュー -->
            <div class="bg-slate-100 border-b border-navy-700/50 overflow-hidden h-52 flex items-center justify-center">
              <img
                src={p.architecture}
                alt={`${name} アーキテクチャ図`}
                class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>

            <!-- プロジェクト情報 -->
            <div class="p-5 flex flex-col flex-1">
              <!-- ヘッダー -->
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xl">{p.emoji}</span>
                <span class="text-xs font-mono text-slate-500 bg-navy-700/80 px-2 py-0.5 rounded">{p.number}</span>
                {p.tags.slice(0, 2).map((tag) => (
                  <span class="px-2 py-0.5 bg-accent/10 text-accent text-xs rounded border border-accent/20">{tag}</span>
                ))}
              </div>

              <h2 class="text-base font-bold text-white mb-2 group-hover:text-accent transition-colors">{name}</h2>
              <p class="text-slate-400 text-sm leading-relaxed mb-4 flex-1">{desc}</p>

              <!-- 使用技術 -->
              <div class="flex flex-wrap gap-1.5 mb-4">
                {p.services.map((svc) => (
                  <span class="px-2 py-0.5 bg-navy-700/60 text-slate-400 text-xs rounded">{svc}</span>
                ))}
              </div>

              <a
                href={`/ja/projects/${p.slug}/`}
                class="text-xs text-accent hover:text-accent-light transition-colors flex items-center gap-1 self-end"
              >
                詳細を見る →
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>
