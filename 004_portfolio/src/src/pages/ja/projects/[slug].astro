---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { projects, getProjectBySlug } from '../../../data/projects';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('ja');
const { slug } = Astro.params;
const project = getProjectBySlug(slug!);

if (!project) {
  return Astro.redirect('/ja/projects/');
}

const name = project.nameJa;
const desc = project.longDescJa;
const points = project.pointsJa;
const architecture = project.architecture;
const githubUrl = project.githubUrl;
---

<BaseLayout title={name} ogImage={architecture}>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <!-- パンくず -->
    <nav class="text-sm text-slate-500 mb-8 flex items-center gap-2">
      <a href="/ja/projects/" class="hover:text-accent transition-colors">実績</a>
      <span>›</span>
      <span class="text-slate-300">{name}</span>
    </nav>

    <!-- ヘッダー -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">{project.emoji}</span>
        <span class="text-xs font-mono text-slate-500 bg-navy-800 px-2 py-1 rounded">{project.number}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{name}</h1>
      <div class="flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <span class="px-3 py-1 bg-accent/10 text-accent text-sm rounded border border-accent/20">{tag}</span>
        ))}
      </div>
    </div>

    <!-- 概要 -->
    <section class="mb-10">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-4">概要</h2>
      <p class="text-slate-300 leading-relaxed text-base">{desc}</p>
    </section>

    <!-- 全体構成図 -->
    <section class="mb-10">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-4">全体構成図</h2>
      <div class="bg-white rounded-lg p-4 border border-navy-700/40">
        <img
          src={architecture}
          alt={`${name} アーキテクチャ図`}
          class="w-full h-auto rounded"
          loading="lazy"
        />
      </div>
    </section>

    <!-- 実装のポイント -->
    <section class="mb-10">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-4">実装のポイント</h2>
      <ul class="space-y-3">
        {points.map((point) => (
          <li class="flex gap-3 bg-navy-800/40 border border-navy-700/40 rounded px-4 py-3">
            <span class="w-1.5 h-1.5 bg-accent rounded-full flex-shrink-0 mt-1.5"></span>
            <span class="text-slate-300 text-sm leading-relaxed">{point}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- 使用技術 -->
    <section class="mb-10">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-4">{t('project.tech')}</h2>
      <div class="grid sm:grid-cols-2 gap-2">
        {project.services.map((svc) => (
          <div class="flex items-center gap-3 bg-navy-800/40 border border-navy-700/40 rounded px-4 py-2.5">
            <span class="w-1.5 h-1.5 bg-accent rounded-full flex-shrink-0"></span>
            <span class="text-slate-300 text-sm">{svc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- アクション -->
    <div class="flex items-center gap-4">
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white text-sm rounded transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          コードを見る
        </a>
      )}
      <a href="/ja/projects/" class="inline-flex items-center gap-2 text-accent hover:text-accent-light transition-colors text-sm">
        実績一覧に戻る
      </a>
    </div>
  </div>
</BaseLayout>
