---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { socialLinks } from '../../data/links';

const t = useTranslations('ja');

const skills = [
  { category: 'クラウド (AWS)', items: ['Lambda', 'Bedrock', 'CloudFront', 'S3', 'ECS/ECR', 'RDS/Aurora', 'ElastiCache', 'ALB/NLB', 'VPC', 'IAM', 'EventBridge', 'CloudWatch', 'CloudFormation', 'SAM', 'SSM', 'SES', 'SNS', 'EFS'] },
  { category: '言語', items: ['Python', 'TypeScript', 'Bash'] },
  { category: 'OS / DB', items: ['Linux (RHEL)', 'Windows Server', 'Oracle', 'PostgreSQL', 'MSSQL Server'] },
  { category: 'ミドルウェア / ツール', items: ['Docker', 'Tomcat', 'VMware', 'FortiGate', 'HULFT', 'OpenLiberty', 'Astro', 'Tailwind CSS', 'Git'] },
];

const awsCerts = [
  { name: 'Solutions Architect Professional', abbr: 'SAP', year: '2021' },
  { name: 'DevOps Engineer Professional', abbr: 'DOP', year: '2024' },
  { name: 'Solutions Architect Associate', abbr: 'SAA', year: '2021' },
  { name: 'SysOps Administrator Associate', abbr: 'SOA', year: '2022' },
  { name: 'Developer Associate', abbr: 'DVA', year: '2022' },
  { name: 'Data Engineer Associate', abbr: 'DEA', year: '2021' },
  { name: 'ML Engineer Associate', abbr: 'MLA', year: '2025' },
  { name: 'Security Specialty', abbr: 'SCS', year: '2024' },
  { name: 'AI Practitioner', abbr: 'AIF', year: '2025' },
  { name: 'Cloud Practitioner', abbr: 'CLF', year: '2021' },
];

const otherCerts = [
  { name: 'LPIC-3 Enterprise Virtualization & HA', year: '2022' },
  { name: 'LPIC Level 2 (201・202)', year: '2022' },
  { name: 'LPIC Level 1 (101・102)', year: '2021' },
  { name: 'CCNA', year: '2023' },
  { name: 'ITIL Foundation', year: '2021' },
  { name: 'Oracle Bronze DBA', year: '2021' },
  { name: 'HULFT Basic Engineer', year: '2025' },
];

const career = [
  {
    period: '2024.11 — 現在',
    title: '大手金融機関 社内システムインテグレーション / スマホアプリ追加機能',
    desc: '2件のAWSプロジェクトを並行担当。要件定義〜試験まで全フェーズを経験。CloudFormationによるIaC、CloudWatch/EventBridge/Lambdaを組み合わせた監視設計を実施。PLへの技術支援・顧客折衝も担当。',
    tags: ['EC2', 'RDS/Aurora', 'ALB/NLB', 'CloudFormation', 'CloudWatch', 'EventBridge', 'Lambda', 'HULFT', 'OpenLiberty'],
  },
  {
    period: '2023.08 — 2024.08',
    title: '大手金融機関 カスタマー向けWebサイト構築',
    desc: 'ECS + Auto Scalingで高可用性・スケーラブルなWebインフラを構築。CloudFormationでIaC化し複数環境への再現性あるデプロイを実現。監視設計・リリース手順書・運用ドキュメント整備まで一貫して担当。',
    tags: ['ECS/ECR', 'RDS/Aurora', 'ElastiCache', 'CloudFront', 'ALB/NLB', 'CloudFormation', 'Docker', 'Tomcat'],
  },
  {
    period: '2023.04 — 2023.07',
    title: '社内AWS基盤構築・運用',
    desc: 'Cost Explorerによるコスト監視・月次報告。AWS CLIでVPC/EC2/S3/IAMを展開し社内環境を整備。',
    tags: ['VPC', 'EC2', 'S3', 'IAM', 'CloudFormation', 'AWS CLI'],
  },
  {
    period: '2022.10 — 2022.11',
    title: '社内システム設計・構築',
    desc: 'FortiGateのバージョンアップ向け疑似環境を設計・構築。draw.ioでAWS構成図を作成し関係者向けプレゼン実施。',
    tags: ['FortiGate', 'Linux', 'draw.io'],
  },
  {
    period: '2021.09 — 2022.09',
    title: 'データセンター ネットワーク運用・監視（通信キャリア向け）',
    desc: '物理サーバ・ネットワーク機器の運用監視。構成変更・切り分け・障害一次対応。固定資産管理・外部業者との工事窓口。',
    tags: ['Linux', 'VMware'],
  },
  {
    period: '2021.05 — 2021.07',
    title: 'Oracle DB 構築・運用',
    desc: 'Oracle 19c インストール・CDB/PDB構築。12c→19c移行検証（RAT）。RHEL 8.2上での初期セットアップ。',
    tags: ['Oracle 19c', 'RHEL 8.2', 'RAT'],
  },
];
---

<BaseLayout title={t('about.title')}>
  <div class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-14">
      <h1 class="text-4xl font-bold text-white mb-2">{t('about.title')}</h1>
      <div class="w-12 h-0.5 bg-accent"></div>
    </div>

    <!-- プロフィール -->
    <section class="mb-16">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-6">{t('about.profile')}</h2>
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="flex-shrink-0 w-20 h-20 rounded-full bg-navy-800 border-2 border-accent/60 overflow-hidden shadow-lg shadow-accent/10">
          <svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <defs>
              <linearGradient id="avatarGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#0ea5e9;stop-opacity:1" />
                <stop offset="100%" style="stop-color:#38bdf8;stop-opacity:1" />
              </linearGradient>
            </defs>
            <rect width="80" height="80" fill="#0f1f3d"/>
            <!-- 回路線 -->
            <line x1="10" y1="40" x2="25" y2="40" stroke="#0ea5e9" stroke-width="1" opacity="0.4"/>
            <line x1="55" y1="40" x2="70" y2="40" stroke="#0ea5e9" stroke-width="1" opacity="0.4"/>
            <line x1="40" y1="10" x2="40" y2="25" stroke="#0ea5e9" stroke-width="1" opacity="0.4"/>
            <line x1="40" y1="55" x2="40" y2="70" stroke="#0ea5e9" stroke-width="1" opacity="0.4"/>
            <circle cx="10" cy="40" r="2" fill="#0ea5e9" opacity="0.5"/>
            <circle cx="70" cy="40" r="2" fill="#0ea5e9" opacity="0.5"/>
            <circle cx="40" cy="10" r="2" fill="#0ea5e9" opacity="0.5"/>
            <circle cx="40" cy="70" r="2" fill="#0ea5e9" opacity="0.5"/>
            <!-- 外周リング -->
            <circle cx="40" cy="40" r="27" fill="none" stroke="url(#avatarGrad)" stroke-width="1.5" opacity="0.6"/>
            <!-- イニシャル -->
            <text x="40" y="46" text-anchor="middle" font-family="monospace" font-size="20" font-weight="bold" fill="url(#avatarGrad)" letter-spacing="1">Z0</text>
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-white mb-1">Zer0_Infra</h3>
          <p class="text-accent text-sm mb-3">クラウドエンジニア / インフラエンジニア</p>
          <p class="text-slate-300 leading-relaxed mb-4">{t('about.profile.text')}</p>
          <div class="flex gap-3">
            <a href={socialLinks.github} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-700/60 hover:bg-slate-600/60 text-slate-200 text-xs rounded border border-slate-600/50 transition-colors">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
            <a href={socialLinks.x} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-700/60 hover:bg-slate-600/60 text-slate-200 text-xs rounded border border-slate-600/50 transition-colors">
              X @Zer0_Infra
            </a>
            <a href={socialLinks.credly} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-orange-900/30 hover:bg-orange-800/40 text-orange-300 text-xs rounded border border-orange-700/40 transition-colors">
              🏅 Credly
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- スキル -->
    <section class="mb-16">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-6">{t('about.skills')}</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {skills.map(({ category, items }) => (
          <div class="bg-navy-800/40 border border-navy-700/50 rounded-lg p-5">
            <h3 class="text-slate-400 text-xs uppercase tracking-wider mb-3">{category}</h3>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <span class="px-3 py-1 bg-navy-700/60 text-slate-200 text-sm rounded border border-navy-600/50">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 資格 -->
    <section class="mb-16">
      <h2 class="text-accent text-xs uppercase tracking-wider mb-6">{t('about.certifications')}</h2>
      <div class="mb-5">
        <a href="https://www.credly.com/users/zer0_infra" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-4 py-2 bg-navy-800/40 border border-accent/40 rounded-lg text-accent text-sm hover:border-accent hover:bg-navy-700/40 transition-colors">
          <span>🏅</span>
          <span>Credly でバッジを確認する</span>
          <span class="text-slate-500 text-xs">↗</span>
        </a>
      </div>
      <div class="mb-6">
        <h3 class="text-slate-400 text-xs uppercase tracking-wider mb-4">AWS Certifications — 10</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {awsCerts.map(({ name, abbr, year }) => (
            <div class="bg-navy-800/40 border border-accent/30 rounded-lg p-3 text-center hover:border-accent/60 transition-colors">
              <div class="text-accent font-bold text-sm mb-1">{abbr}</div>
              <div class="text-slate-300 text-xs leading-tight mb-1">{name}</div>
              <div class="text-slate-500 text-xs">{year}</div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-slate-400 text-xs uppercase tracking-wider mb-4">Other Certifications</h3>
        <div class="grid md:grid-cols-2 gap-3">
          {otherCerts.map(({ name, year }) => (
            <div class="flex items-center justify-between bg-navy-800/40 border border-navy-700/50 rounded-lg px-4 py-3">
              <span class="text-slate-200 text-sm">{name}</span>
              <span class="text-slate-500 text-xs ml-2 flex-shrink-0">{year}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 職務経歴 -->
    <section>
      <h2 class="text-accent text-xs uppercase tracking-wider mb-6">{t('about.career')}</h2>
      <div class="relative">
        <div class="absolute left-4 top-0 bottom-0 w-px bg-navy-700/60"></div>
        <div class="space-y-8">
          {career.map(({ period, title, desc, tags }) => (
            <div class="relative pl-12">
              <div class="absolute left-3 top-1.5 w-2.5 h-2.5 rounded-full bg-accent border-2 border-navy-900 -translate-x-1/2"></div>
              <div class="text-accent text-xs mb-1">{period}</div>
              <h3 class="text-white font-semibold mb-2">{title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-3">{desc}</p>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="px-2 py-0.5 bg-navy-700/60 text-slate-300 text-xs rounded border border-navy-600/50">{tag}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
